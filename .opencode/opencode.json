{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "default_agent": "orchestrator",
  "instructions": [
    "docs/AGENTS.md"
  ],
  "lsp": true,
  "share": "manual",
  "snapshot": true,
  "tool_output": {
    "max_lines": 1000,
    "max_bytes": 32768
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 8
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.example": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "task": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "skill": "allow",
    "external_directory": {
      "*": "ask",
      "~/projects/**": "allow",
      "/home/erenimo/projects/**": "allow",
      "/tmp/opencode/**": "allow"
    },
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "sudo *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "git push*": "ask",
      "git reset*": "ask",
      "git clean*": "ask",
      "git checkout*": "ask",
      "git restore*": "ask",
      "git rebase*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "npm run lint*": "allow",
      "npm run test*": "allow",
      "uv run ruff check*": "allow",
      "uv run pytest*": "allow"
    }
  }
}
