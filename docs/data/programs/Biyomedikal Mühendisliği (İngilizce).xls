<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 027</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Genomics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Proteomics, Epigenomics, Pharmacogenomics for Personalized Therapy, Current Place of Pharmacogenomics in Personalized Therapy, Toxicogenomics, Spliceomics, Glycomics, Breast Cancer Biomarkers and Their Use in Early Diagnosis, Plant Metabology, Metagenomics, Environmental Pollutants in the Evaluation of Environmental Pollutants, Toxicogenomic Applications Includes headings.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412396&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
