<Cell ss:StyleID="Text"><Data ss:Type="String">BME 556</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biomedical Signal Processing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Probability distribution and density function of 1D random, Conditional distribution and additive random variables, Normal distribution and the central limit theorem.</Data></Cell>
