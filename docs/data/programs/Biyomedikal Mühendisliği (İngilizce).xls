<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 528</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Electromagnetic and Photonic Interactions with Biological Media</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">06.02.2026</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">• Electromagnetic and optical interactions with biological tissue
• Electrical, magnetic, and optical properties of biological media
• Energy deposition, tissue heating, and thermal damage
• Measurement techniques and tissue phantom validation
• Safety limits and exposure standards
• Applications in fNIRS and magnetic hyperthermia
• Student-led device physics presentations</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=447623&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 530</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Polymeric Biomaterials</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The multidisciplinary subject of biomedical application of materials obtained from natural and synthetic sources. Solid properties, various materials used in biomaterials, tissue-material interactions, in situ, in vitro and in vivo application methods and sterilization are discussed. Important soft and hard tissue applications involving tissue engineering, drug delivery, implant design, and imaging are discussed with special emphasis on bio and synthetic polymers.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412553&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 531</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Selected Topics in Biological Mass Spectrometry</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">intact-reduced mass, peptide mapping, post-translation modification, glycan analysis, disulfide bond analysis of monoclonal antibodies via mass spectrometric techniques</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412562&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 537</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biomems</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">This course introduces students to the multi-disciplinary and exciting field of MicroElectroMechanical Systems (MEMS). It teaches the underlying physical principles, methods of fabrication (hard and soft lithography techniques, 3D printing, thin-film deposition, and materials printing) and applications of a broad range of mechanical and optical devices and systems as well as biomedical systems (BioMEMS).</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412563&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 539</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412574&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 544</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Photosensitisers for Photodynamic Applications</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">06.02.2026</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction of photodynamic therapy (PDT) principles and mechanisms, introduction to the chemistry of porphyrinoids are explained.
Porphyrin-based and Phthalocyanine-based photosensitizers for anti-cancer PDT,targeting strategies for anti-cancer PDT,Nanoparticles &amp; theranostics in anti-cancer PDT,other types of photosensitizers and antimicrobial PDT are explained.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412568&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 545</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Tissue Engineering and Scaffold Desing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Principles of tissue engineering and its main application areas, Properties of a suitable scaffold and its design strategies, Outstanding studies in recent literature</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412566&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 546</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Theranostic Nanoparticles</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction of theranostic nanoparticle types and some imaging methods.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412556&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 554</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Advances in Ophthalmic Biotechnology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Microfabrication, Micropatterning of Substrates and cells, Microfluidics, Molecular Biology on a chip, BioMEMS for Cell Biology Tissue Microengineering, Implantable Microdevices</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412552&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 555</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Medical Image Processing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The course will introduce the basic physical principles that enable information about the tissues in the body to be received in the form of signals, taking into account the main physical principles used, under 4 main headings: transmission-based methods (for example, X-ray), reflection-based methods (for example, Ultrasound), emission-based methods (in ex. SPECT / PET) and resonance-based methods (MRI / fMRI).</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412368&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 556</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biomedical Signal Processing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">This course introduces two fundamental concepts of signal processing: linear systems and stochastic processes. Various estimation, detection and filtering methods are developed and demonstrated on biomedical signals. The methods include harmonic analysis, autoregressive model, Wiener and Matched filters, linear discriminants, and independent components. All methods will be developed to answer concrete question on specific data sets in modalities such as ECG, EEG, MEG, Ultrasound. The lectures will be accompanied by data analysis assignments using MATLAB.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412359&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 557</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biosensors</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Overview of biosensor applications,Desired characteristics of biosensors,Chemical reactions,Enzymes,Cells,Antibodies,Nucleic Acids (RNA and DNA),Labels,Immobilization, Seismic (mass) and thermal sensors, Electrochemical sensors, Optical sensors</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412510&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 558</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biomechanics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">In this course, kinematics, motion biomechanics in anthropometry, Kinetics: Force and Torque , Work, energy and power , the body coordinate system,Human Movement and muscle mechanics, postural control , balance, linear and angular movement will be taught.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412509&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 559</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Mathematical Basis of Computational Neuroscience</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The course offers an introduction to modeling methods in neuroscience. It illustrates how models can extend and evaluate neuroscience concepts. Basic techniques of modeling biophysics, excitable membranes, small network and large scale network systems will be introduced. The course begins with a consideration of mathematical models of excitable membranes, including the Hodgkin-Huxley model and simplifications such as the Morris-Lecar and FitzHugh-Nagumo models. It will provide hands-on laboratory experience in modeling membranes, neurons, and neural networks. The course explores the use of differential equations, numerical simulation, and graphical techniques for modeling compartmental and connectionist neural systems. The range of topics include simulations of electrical properties of membrane channels, single cells, neuronal networks and connectionist simulation. Students will be afforded laboratory experience in computer modeling, and they will develop computational neuroscience models in the course. Prerequisites for the course include basic knowledge of calculus, neuroscience, and some computer programming.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412367&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 560</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Functional Neuroimaging</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">This course gently introduces the physical and physiological principles of fMRI signal formation and the state-of-the art methods and models used for fMRI analysis. The course will cover computational aspects of preprocessing the anatomical and functional images, convolution models for fMRI, a review of the general linear model, contrast vectors and classical inference, hierarchical models, modeling brain connectivity and optimizing experimental design.
The theoretical lectures will be complemented with hands-on practical sessions which will familiarize the students with some of the freely available comprehensive libraries of analysis tools such as FSL (https://fsl.fmrib.ox.ac.uk) and SPM (http://www.fil.ion.ucl.ac.uk/spm). Background concepts and practicalities of the analyses will be taught in detailed lectures which will be followed by computational assignments that guide the students through all the analysis steps using real data.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412366&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 561</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nanomedicine</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Principles of NanoBioTechnology and its main applications in medicine areas, Properties of a nanomedicine platform and its design strategies, Outstanding studies in recent literature.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412503&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 562</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Polymeric Biomaterials</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The multidisciplinary subject of biomedical application of materials obtained from natural and synthetic sources. Solid properties, various materials used in biomaterials, tissue-material interactions, in situ, in vitro and in vivo application methods and sterilization are discussed. Important soft and hard tissue applications involving tissue engineering, drug delivery, implant design, and imaging are discussed with special emphasis on bio and synthetic polymers.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412505&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 563</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Selected Topics in Biological Mass Spectrometry</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Intact-reduced mass, peptide mapping, post-translation modification, glycan analysis, disulfide bond analysis of monoclonal antibodies via mass spectrometric techniques</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412358&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 564</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BioMEMS</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">This course introduces students to the multi-disciplinary and exciting field of MicroElectroMechanical Systems (MEMS). It teaches the underlying physical principles, methods of fabrication (hard and soft lithography techniques, 3D printing, thin-film deposition, and materials printing) and applications of a broad range of mechanical and optical devices and systems as well as biomedical systems (BioMEMS).</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412360&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 565</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Epigenetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Mechanisms, Epigenetics in Other Organisms,
Includes Functional Epigenetics, Epigenetic Epidemiology, Epigenetic Control Examples, Drugs and Epigenetics.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412365&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 566</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Culture of Cells in Tissue Engineering</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Basic principles of cell culture are given and the main focus is on procedures for obtaining, manipulating, and using cell sources for tissue engineering. Limited number of diverse, important, and successful tissue engineering systems are discussed by providing both the general background and the detailed protocols for each tissue engineering system.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412362&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 567</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Advances in Biomaterials</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Latest developments in the Biomaterials field will be introduced with special emphasis on biocompatibility of materials, sterilization of biomedical devices, tissue engineering and cell biomaterials interactions, drug delivery via biodegradable vehicles, hard tissue implants and bone cements.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412508&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 568</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Photosensitisers for Photodynamic Applications</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction of photodynamic therapy (PDT) principles and mechanisms, introduction to the chemistry of porphyrinoids are explained.
Porphyrin-based and Phthalocyanine-based photosensitizers for anti-cancer PDT,targeting strategies for anti-cancer PDT,Nanoparticles &amp; theranostics in anti-cancer PDT,other types of photosensitizers and antimicrobial PDT are explained.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412511&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 569</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Tissue Engineering and Scaffold Desing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Principles of tissue engineering and its main application areas, Properties of a suitable scaffold and its design strategies, Outstanding studies in recent literature</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412361&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
