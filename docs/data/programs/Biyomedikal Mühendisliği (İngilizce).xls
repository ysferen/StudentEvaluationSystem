<Cell ss:StyleID="Text"><Data ss:Type="String">Increase awareness of individual differences and about oneself,</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412462&amp;lang=en</Data></Cell>
