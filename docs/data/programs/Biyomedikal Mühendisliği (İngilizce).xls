<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBT 567</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Aptamer-based Nanotecnology Applications</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Within the scope of the course, basic principles will be explained to the students according to the weekly topics given, applied studies in the relevant topics will be discussed through discussions on articles.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412369&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
