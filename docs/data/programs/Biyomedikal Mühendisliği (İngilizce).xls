<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 156</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sports for All</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">In all segments of society, old, young, children, women, men, healthy, disabled, fit, fit people in existing natural conditions or in areas created later, for health with or without tools, or for the positive assessment of leisure time, providing physiological and psychological benefits to gain scientific competence that can make sports.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412422&amp;lang=en</Data></Cell>
