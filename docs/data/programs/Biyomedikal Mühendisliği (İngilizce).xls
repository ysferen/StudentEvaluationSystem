<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Immobilization of biorecognition element; conjugation of labels</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
