<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 524</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nanomedicine</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">14</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Presentations of selected publications (team work)
Related to NanoTheranostic</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412551&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 528</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Electromagnetic and Photonic Interactions with Biological Media</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Electromagnetic Spectrum and Energy Concepts in Biological Media
• Field, wave, and particle descriptions of electromagnetic energy
• Frequency, wavelength, photon energy, and penetration concepts
• Near-field vs far-field interactions in tissue
• Power, intensity, fluence, and energy density
• Why different spectral regions interact differently with tissue</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=447623&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 528</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Electromagnetic and Photonic Interactions with Biological Media</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Electrical and Dielectric Properties of Biological Tissues
• Electrical conductivity, permittivity, and magnetic permeability
• Complex permittivity and dispersive tissue behavior
• Cell membranes as capacitive–resistive interfaces
• Anisotropy and structural inhomogeneity in tissues
• Phantom materials as electromagnetic tissue surrogates</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=447623&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 528</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Electromagnetic and Photonic Interactions with Biological Media</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Static and Quasi-Static Magnetic Field Interactions with Tissue
• Magnetic field sources and field geometry
• Lorentz force in conductive biological media
• Magnetic forces on particles and field gradients
• Dia-, para-, and superparamagnetic responses
• Static vs inductive low-frequency magnetic interactions</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=447623&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 528</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Electromagnetic and Photonic Interactions with Biological Media</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Photon Propagation in Absorbing and Scattering Media
• Absorption, scattering, and reflection mechanisms
• Beer–Lambert law in tissue
• Penetration depth and optical windows
• Multiple scattering and diffuse photon transport
• Why tissue is optically translucent rather than transparent</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=447623&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 528</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Electromagnetic and Photonic Interactions with Biological Media</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Energy Deposition and Tissue Heating by Electromagnetic Fields and Photons
• Joule heating and electromagnetic power dissipation
• Optical absorption and photothermal conversion
• Heat diffusion and thermal boundary conditions
• Transient vs steady-state temperature rise
• Physical mechanisms of thermal tissue damage</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=447623&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 528</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Electromagnetic and Photonic Interactions with Biological Media</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Measurement Principles for Electromagnetic and Optical Tissue Interactions
• Electric and magnetic field measurement principles
• Optical power, intensity, and transmission measurements
• Temperature sensing in tissue and phantoms
• Signal-to-noise limits in biological measurements
• Calibration and validation using controlled phantoms</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=447623&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BME 528</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Electromagnetic and Photonic Interactions with Biological Media</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physical Safety Limits, Exposure Constraints, and Scaling Laws
• Specific Absorption Rate (SAR)
• Optical fluence and radiant exposure limits
• Thermal damage thresholds in tissue
• Time–power–distance scaling laws
• Why laboratory safety ? clinical safety</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=447623&amp;lang=en</Data></Cell>
</Row>
