<Worksheet ss:Name="ProgramOutcomes">
<Table>
<Column ss:Width="220"/>
<Column ss:Width="70"/>
<Column ss:Width="110"/>
<Column ss:Width="750"/>
<Column ss:Width="420"/>
<Row>
<Cell ss:StyleID="Header"><Data ss:Type="String">ProgramName</Data></Cell>
<Cell ss:StyleID="Header"><Data ss:Type="String">ProgramId</Data></Cell>
<Cell ss:StyleID="Header"><Data ss:Type="String">ProgramOutcomeNo</Data></Cell>
<Cell ss:StyleID="Header"><Data ss:Type="String">ProgramOutcomeText</Data></Cell>
<Cell ss:StyleID="Header"><Data ss:Type="String">SourceUrl</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği özelinde matematik, istatistik, temel bilim ve karmaşık mühendislik problemlerini uygulama yetisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=6247</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Karmaşık mühendislik problemlerini tanımlama, çözme, uygun analiz yöntemlerini seçme ve uygulama becerisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=6247</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Modern tasarım yöntemlerini kullanarak ve uygulayarak karmaşık bir sistem, cihaz ya da ürünü belirli gereksinimleri karşılayacak şekilde geliştirme becerisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=6247</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği mesleğini yapabilmek için gerekli yöntemler, beceriler ve güncel mühendislik araç-gereçlerini ve bilişim teknolojilerini etkin bir şekilde kullanabilme yetisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=6247</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Karmaşık mühendislik problemlerinin çözümü için deney tasarlama, deneyleri gerçekleştirme, veri toplama, sonuçların analiz edilmesi ve yorumlanması becerisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=6247</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Bireysel olarak ve çok disiplinli takımlar içinde etkin çalışabilme becerisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=6247</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">İngilizce bilgisi, sözlü ve yazılı etkin iletişim, talimat alma-verme, rapor yazma-anlama ve sunum yapabilme becerisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=6247</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Yaşam boyu öğrenmenin gerekliliği hakkında farkındalık, bilim ve teknolojideki gelişmeleri takip etme, gerekli bilgiye erişme ve yaşam boyu öğrenmeye devam etme becerisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=6247</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Etik ve mesleki sorumluluklar ile mühendislik uygulamalarında kullanılan standartların neler olduğunu kavramış olma ve bu sorumlulukları Biyomedikal Mühendisliği alanında uygulama becerisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=6247</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Mühendislik uygulamalarında proje ve risk yönetimi uygulamaları, girişimcilik, sürdürülebilir kalkınma ve yenilikçi biyomedikal teknolojileri hakkında bilgi edinme becerisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=6247</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği (İngilizce)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyomedikal Mühendisliği’nin sağlık, çevre ve toplumsal boyutlardaki etkisini bilme ve mühendislik uygulamalarının sonuçlarını etik ve diğer açılardan değerlendirme farkındalığı kazanma becerisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=6247</Data></Cell>
</Row>
</Table>
