<Cell ss:StyleID="Text"><Data ss:Type="String">Biomedical Signal Processing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Convolution theorem, Linear versus circular convolution, Overlap-save implementation of linear convolution, Windowing</Data></Cell>
