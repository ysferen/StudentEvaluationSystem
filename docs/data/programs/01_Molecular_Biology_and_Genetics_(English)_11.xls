</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 037</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Virology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">05.02.2026</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">This course covers the theory and application of virology in health and biological research. Topics include The Infectious Cycle, Genomes and Genetics, Structure Attachment and Entry, molecular and cellular biology of viruses. Special emphasis is placed on HIV and Coronavirus and how they affect human society.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=408738&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 038</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Fluorescent Techniques</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">05.02.2026</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">This course covers the theory and application of fluorescence techniques in biological research, with a focus on microscopy, flow cytometry and fluorescent protein function. Topics include Fluorescence vs Absorbance, Fluorescent Microscopy, Flow Cytometry, FACS Sorting, and Confocal microscopy. Special emphasis is placed on data acquisition software and data analysis techniques.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=408737&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBT 521</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Principles of Biotechnology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Why is biotechnology? What are cell typing techniques? What is cell culture and where is it used? What is the importance of enzymes in biotechnology? How is microbial culture technology and fermentation applications used? What are the principles of protein engineering, bioinformatics and molecular modeling, vaccine development, tissue engineering, diagnosis, drug development, moral issues in applications, and patent?</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274059&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBT 538</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Microscopic Techniques</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1) Basic principles physics of light
2) Basic principles of light microscopy
3) Visualization methods in light microscopy
4) Basic principles of electron microscopies
5) Tissue proccessings related to microscopy techniques
6) High-end microscopy techniques
7) Basic principles of confocal microscopy and its application areas
8) Basic principles of fluorescent microscopy and its application areas
9) Basic principles ofmultiphoton microscopy and its application areas
10) Basic principles of focused ion beam scanning electron microscopy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274062&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBT 544</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Medical Parasitology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The content of the lecture of Medical Parasitology encompasses the general features, clinical manifestations, public-health significance and the diagnostic methods of parasitic infections, which threaten the human health.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274061&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBT 549</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Fungal Biotechnology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1 Fungal Diversity, Physiology and Architecture
2 Fungal Growth
3 Fungal Metabolism and Metabolic Engineering
4 Fungi as Model Organisms
5 Molecular Tool Kits for Fungal Biotechnology-I
6 Molecular Tool Kits for Fungal Biotechnology-II
7 Genetic Manipulation Systems for Yeast-I
8 Genetic Manipulation Systems for Yeast-II
9 Fungal Gene &amp; Genome Editing Technologies
10 Application of Genetic Engineering for Strain Improvement in Filamentous Fungi
11 Fungi as Producers of Biopharmaceuticals-I
12 Fungi as Producers of Biopharmaceuticals-II
13 Systems Biology of Fungi-I
14 Systems Biology of Fungi-II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274060&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBT 550</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">General Principles of Medical Pharmacology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1 Introduction to pharmacology
2 Drug invention and the pharmaceutical industry
3 Pharmacokinetics: Drug absorption and distribution
4 Pharmacokinetics: Drug metabolism and elimination
5 Pharmacodynamic concepts
6 Pharmacodynamics: Mechanisms of drug action
7 Drug interactions and factors affecting drug actions
8 Pharmacogenetics: receptors, transporters and enzymes polymorphisms
9 Membrane transporters and drug response
10 Clinical trials and drug research
11 Toxicology studies
12 Drugs affecting autonomous nervous system
13 Drugs affecting cardiovascular function
14 Assessment</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274063&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBT 567</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Aptamer-based Nanotecnology Applications</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Weekly teaching of fundemantal information, discussions on related articles</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274058&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 307</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Microbiology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+2+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">15.10.2024</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Learn the properties of bacteria, fungi and parasites and techniques such as staining sterilization medium and microscopy for the examination of these microorganisms.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274144&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 313</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biochemistry I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The properties of aqueous systems, the structures and functions of biological bonds and interactions, primary, secondary, tertiary and quarternary structures of proteins, protein motifs and domains, working principles of enzymes, enzyme kinetics and regulatory enzymes</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274142&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 315</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Research Techniques in Biochemistry and Genetics I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1+4+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">15.10.2024</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Laboratory record keeping and report writing guidelines, Human cell culture, Cell distruption, Total protein extraction and quantitation techniques, Cell extract preparation, Protein assays , Electrophoresis techniques - Native and SDS-PAGE, Gel imaging and staining techniques, Western blot techniques, DNA isolation techniques and calculations, DNA and RNA isolation techniques and calculations</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274143&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 308</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Immunology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Innate immunity, the induced innate immune response, antigen recognition by B-cell and T-cell receptors, B cell development and survival, T cell development and survival, humoral immune response, cellular immune response and autoimmune diseases</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274149&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 316</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Research Techniques in Biochemistry and Genetics II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1+4+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">15.10.2024</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Gene expression, methods used, plasmid DNA, plasmid amplification in bacteria, plasmid DNA isolation, transfection into mammalian culture, introduction of experimental animals, organ harvesting from experimental animals, staining from tissue sections and microscopy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274148&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
