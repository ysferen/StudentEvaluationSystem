<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 173</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Law</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Learn the reflections of public and private law, which are covered by health law at the basic level; cases that will cause compensation and acts that will cause criminal sanctions.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274041&amp;lang=en</Data></Cell>
</Row>
