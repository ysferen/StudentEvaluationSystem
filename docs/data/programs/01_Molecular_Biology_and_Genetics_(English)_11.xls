<Cell ss:StyleID="Text"><Data ss:Type="String">PHY 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physics I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
