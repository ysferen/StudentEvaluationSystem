<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 036</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=408739&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
