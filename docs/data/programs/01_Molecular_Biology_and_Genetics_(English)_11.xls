<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 208</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of Thought</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Presenting examples from the history of human thought/philosophy starting from the Ancient Greek Thought extending to 20th century Phenomenology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274011&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 212</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English Language Course For Erasmus II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">This course is for students who wish to prepare for the University’s Erasmus English Proficiency Exam and other internationally recognised test such as IELTS, TOEFL . The lesson covers both examination skills and techniques and work on improving all aspects of the students’ English: speaking, listening, reading, writing, grammar, pronunciation and vocabulary.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274014&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 213</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English Language Course For Erasmus I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">30.01.2024</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">B2 Level English</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274013&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 221</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of the Horror Film</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">30.01.2024</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The course will include various guides to understand the genre as a set of narrative conventions, an industrial category, and an affective relationship to the screen. Students can expect to examine a variety of cinematic texts from a mix of critical lenses.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274043&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 223</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Modern Scientific Research Methods</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Scientific research methods, quantitative and qualitative study examples, data analysis through a statistical program, research results, publication and writing techniques, and reporting.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274160&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 224</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Employment Skills</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">In the course, students will be informed about the importance of career planning, skills for employment, job search, application processes, resume preparation, interview skills, how to behave in the event of entering, promotion or leaving the job. Experts will be invited to the course in certain weeks.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274158&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 225</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Strategic Brand Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">31.01.2024</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Course Content In this course, students will be informed about the key concepts of brand and marketing management. Marketing is a structured process, henceforth, the course will teach how to formulate strategies to engage new and current customers as well as generate sales. Students who attend this course are expected to improve their commercial focus and acquire skills to influence business growth.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=288404&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 226</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Project Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
