<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ATA 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ataturk&apos;s Principles and History of Revolution I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students learn the phenomenon of modernization.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=273999&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ATA 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ataturk&apos;s Principles and History of Revolution I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students learn geographical discoveries, Renaissance and reform movements, Enlightenment, French Revolution, the establishment of the United States and their impact on the Ottoman Empire.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=273999&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ATA 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ataturk&apos;s Principles and History of Revolution I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students learn the emergence of global trade, industrial revolution and their transformations.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=273999&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ATA 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ataturk&apos;s Principles and History of Revolution I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students learn the Industrial Revolution, imperialism and their effects on the Ottoman Empire.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=273999&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ATA 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ataturk&apos;s Principles and History of Revolution I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students understand the reasons of the Ottoman Empire&apos;s disintegration and disintegration.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=273999&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ATA 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ataturk&apos;s Principles and History of Revolution I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students comprehend the foundation of the Republic, Ataturk’s principles and revolutions with different dynamics.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=273999&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ENG 105</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English for Academic Purposes I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Identify common challenges in early higher education; be aware of expectations of higher education institutions; identify factors involved in good time management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=273995&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ENG 105</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English for Academic Purposes I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Understand the requirements of writing an academmic essay; analyze essay questions; organize ideas to produce a clear outline; write an effective introduction with clear thesis statement; plan and structure the main part of an academic essay; writing a compelling conclusion; identify features of academic style, formal &amp; objective language</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=273995&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ENG 105</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English for Academic Purposes I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Identify key features of group work; recognize benefits and challenges of group work; set goals and objectives; plan and organize a group project; understand expectations in group discussions; employ useful language for contributing to academic discussions; identify verbal and non-verbal clues during conversations; identify techniques for encouraging and discourgaing interaction</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=273995&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ENG 105</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English for Academic Purposes I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Understand the difference between thinking and critical thinking, fact and opinion; identify parts of and evaluate arguments, recognize weak aguments; consider sources of bias in evidence in academic research; use critical thinking in a variety of styles to construct arguments</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=273995&amp;lang=en</Data></Cell>
</Row>
