<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 232</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Social Roles and Identities</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
