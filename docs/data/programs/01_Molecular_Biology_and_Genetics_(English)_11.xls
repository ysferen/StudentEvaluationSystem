<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 419</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Senior Project I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1+6+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students will have the ability to discover new things, to solve problems, to gain time management skills, to obtain and present data, to read and write scientific articles, to conduct scientific research specific to the subject.</Data></Cell>
