<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1+2+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2,5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.09.2023</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1. Basic Statistics Concepts
2. Submission of Data
3. Summary of Data
4. Statistics and Probability
5. Hypothesis Testing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=274113&amp;lang=en</Data></Cell>
