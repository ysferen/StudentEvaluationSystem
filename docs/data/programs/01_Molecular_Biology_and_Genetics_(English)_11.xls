<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Moleküler Biyoloji ve Genetik alanında güncel teorik ve uygulama ile desteklenen temel bilgiye sahip olur ve bunları kullanır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Farklı organizmalardaki gen ve hücrenin moleküler yapısını ve işleyişini, kontrol mekanizmalarını ve hücrenin moleküler özelliklerini bilir.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biyoinformatikteki temel kavramları ve moleküler biyoloji ve genetik alanındaki uygulamalarını kavrar.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Moleküler biyoloji ve genetiğin gen mühendisliği ve biyoteknoloji, kanser biyolojisi ve kök hücre ve hücre tedavisi uygulamaları hakkında bilgi sahibi olur.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Gen ve hücre teknolojileri alanında elde ettiği bilgi ve becerileri evrensel bilim etiği kurallarını dikkate alarak değerlendirir ve uygulamaya aktarır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Gen ve hücre yapı ve işleyişi ile ilgili bilgi ve becerilerini farklı disiplinlere uygulama becerisi kazanır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Bilimsel süreç işleyişinden haberdardır, eleştirel düşünür, moleküler biyolojideki deneysel ve teorik yaklaşımlarla soru sorma yetisine sahiptir.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Moleküler biyoloji ve genetik alanında bağımsız araştırma planlayabilme ve araştırma yürütebilme bilgi ve becerisi kazanır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Moleküler biyoloji, hücre biyolojisi ve genetik alanlarında kullanılan temel laboratuar tekniklerini uygular.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Gen ve hücre moleküler biyolojisi hakkındaki bilgileri farklı organizma gruplarının moleküler özelliklerinin analizinde kullanır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Yeni teknik ve teknolojik zorlukları aşmaya hazır, yaşam boyu öğrenmeye açıktır. Özgün araştırma sonuçlarını ulusal ve uluslararası düzeyde yayımlayıp moleküler biyoloji ve genetik alanında ülkemizin temsil edilmesine ve bilimsel birikiminin artmasına katkı sağlar.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Moleküler biyoloji ve genetik alanındaki konulardan ve bilimsel gelişmelerden haberdardır, ve toplumsal sorumluluk bilinci ile yaşadığı biyolojik ve sosyal çevre için proje ve etkinlikler düzenleyebilir ve bunları uygulayabilir.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">13</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Moleküler Biyoloji ve Genetik alanındaki yetkinlik konuları kapsamında verilerin toplanması, yorumlanması, uygulanması ve sonuçlarının duyurulması aşamalarını gerçekleştirme yeteneğini kazanır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">14</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Moleküler Biyoloji ve Genetik alanındaki yetkinlik konuları kapsamında verilerin toplanması, yorumlanması, uygulanması ve sonuçlarının duyurulması aşamalarında toplumsal, bilimsel, kültürel ve etik değerlere uygun hareket etme yeterliliğine sahiptir.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">15</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Hem grup olarak hem de bireysel olarak bilimsel çalışma sürecine hakimdir.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">16</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Moleküler Biyoloji ve Genetik alanında yeni bir projenin yazılması ve bir projenin takibi konusunda temel bilgilere sahiptir.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=11</Data></Cell>
</Row>
</Table>
