</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 466</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Child Health and Disease Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Çocuğa özgü anatomik ve fizyolojik farklılıkları tanımlar ve hemşirelik girişimlerinde çocuğa özgü farklılıkları dikkate alarak uygulamalarını yapar</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413875&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 466</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Child Health and Disease Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Çocuk ve aile sağlığını değerlendirir, çocuğun sağlığını koruma ve geliştirilmesine katkıda bulunur</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413875&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 466</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Child Health and Disease Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Çocuğun sistemlere özgü hastalıklarını, hastalıkları sırasında yaşadığı fizyolojik ve psikososyal değişimleri analiz eder</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413875&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 466</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Child Health and Disease Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Çocuğun hastalıklar sırasında yaşadığı değişimlere yönelik bireyselliğini anlayan, aile merkezli, holistik ve atravmatik bakım ilkeleri doğrultusunda; tanılama ve etkin bakım yaklaşımlarını geliştirir, uygular ve değerlendirir</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413875&amp;lang=en</Data></Cell>
</Row>
