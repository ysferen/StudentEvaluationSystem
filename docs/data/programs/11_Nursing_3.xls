<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">25.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Weight management, eating disorders, diabetes, hypertension, cardiovascular diseases, digestive system diseases and infectious diseases</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413857&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HSEC 236</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Quality Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">25.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Course content consists of theoretical knowledge and practical application examples.</Data></Cell>
