<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HSEC 323</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Recognizing Forensic Situations</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explains the responsibilities of health workers in cases of domestic violence and child abuse, and the role of nurses in approaching cases of sexual assault.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413919&amp;lang=en</Data></Cell>
</Row>
