<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Internal Medicine Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Act in accordance with the principles of safety while providing health care for the individual and family.</Data></Cell>
