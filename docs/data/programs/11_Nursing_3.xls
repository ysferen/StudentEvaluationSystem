<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 247</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Internal Medicine Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Use nursing process while providing health care for individual and family.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413851&amp;lang=en</Data></Cell>
</Row>
