<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Being able to empathize by playing roles that they wouldn&apos;t be able to enter in real life</Data></Cell>
