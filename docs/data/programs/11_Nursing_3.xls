</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 456</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Surgical Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Multidisipliner ekip içerisinde cerrahi hemşiresinin görev yetki ve sorumluluklarını yerine getirirken yasal ve etik ilkeler doğrultusunda davranış geliştirir</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413835&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 456</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Surgical Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cerrahi hastalıkları hemşireliğindeki temel kavramları tartışır, etkin ve etkili hemşirelik bakım sürecini sürdürür</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413835&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 456</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Surgical Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cerrahi girişim gerektiren hastalıklarda birey/aile/toplumun holistik bakım gereksinimlerini belirler ve hasta/çalışan güvenliği ilkeleri doğrultusunda bakımı planlar</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413835&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 456</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Surgical Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cerrahi girişim gerektiren hastalıklarda birey/aile/toplumun ameliyat öncesi, sırası ve sonrası dönemlerinde bakım gereksinimlerinde güncel sağlık teknolojileri ve kanıta dayalı uygulamaları kullanır</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413835&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 456</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Surgical Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cerrahi girişim gerektiren hastalıklarda birey/aile/toplum ve sağlık ekibiyle işbirliği sağlar ve terapotik iletişimi sürdürür</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413835&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 456</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Surgical Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">En sık cerrahi girişim yapılan hastalıklarda sağlığın korunması ve geliştirilmesinde ulusal/uluslararası bakım önceliklerini belirleyebilir</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413835&amp;lang=en</Data></Cell>
</Row>
<Row>
