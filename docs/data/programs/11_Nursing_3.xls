<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HSEC 323</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Recognizing Forensic Situations</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
