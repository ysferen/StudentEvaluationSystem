<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ATA 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ataturk&apos;s Principles and History of Revolution I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">25.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ottoman and Turkish modernization, the birth of capitalism and industrialization in Europe, imperialism and its effects on the Ottoman Empire, nationalism and nation-states, causes of the collapse of the Ottoman Empire, the 1908 Revolution,The First World War, the struggle for independence and the establishment of a new state, Ataturk’s principles and revolutions are the main topics of this course.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413932&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BIL 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction to Computer I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1+0+2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10.10.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction to Computer: Computer History, hardware, operating systems Windows Operating System Microsoft Office Products Microsoft Office Word Microsoft Office PowerPoint Microsoft Outlook Internet Research, working in different documents</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413947&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 105</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Anatomy I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1+0+2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10.10.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">General knowledge of bones, joints, muscles, Upper extremity bones and joints, Lower extremity bones and joints, Neurocranium, viscerocranium, cranial skeleton, Spinal nerves general introduction, brachial plexus, superficial back and upper extremity muscles, vessels and nerves, Lower extremity muscles , vessels and nerves, Lumbosacral plexus, Anterior abdominal wall topography, muscles and fascia, Digestive system entrance, cavum oris, pharynx, esophagus, stomach, duodenum jejunum, ileum, large intestines, rectum and anal canal, Liver, gallbladder, pancreas, spleen , digestive system vessels and nerves.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413945&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physiology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10.10.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction to Physiology, Excitable Tissues and Action Potential, Synapse structure and Neurotransmitters, Muscle Physiology and Neuromuscular Junction, Nervous system Physiology, Senses, Heart and Circulation, General Properties of Blood, Leukocytes and Immune system, Platelets and Coagulation mechanism.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413949&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">HEM 113</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction to Health Sciences and Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10.10.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Methods of accessing information in Health Sciences, databases and resource scanning and their usage, responsibilities of being an university student, nursing in the World and Turkey from past to present, its historical process, concepts related to health, the nature of nursing and concepts affecting nursing: human, health, disease, environment, nursing education systems; high school, undergraduate, master, doctorate, certificate programs, health policies, Nursing Law and regulations, nursing institutions: ICN, THD, Private Branch associations, occupations offering health care services, Health Care maintenance systems, nursing and evidence based practices as a science, future of nursing, importance of Nursing in the world and in Turkey, health and technology.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413943&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
