<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 183</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Diction</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Learns the rules of diction. Speaks knowing intonation, emphasis, stops. Distinguishes the differences between written language and spoken language. Understands the importance of correct and beautiful speech.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413782&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 184</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Popular Culture, Media and Communication</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Recognizes the concept of popular culture. Discusses approaches to media and mass communication. Understands the means of dissemination of popular culture. Evaluates the reflections of popular culture in daily life.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413785&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 185</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The Art of Living</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Definition of basic thoughts, importance of rational thinking, putting rational thoughts into action, self-development of individuals, definition of happiness, anxiety, sadness, depression, guilt, shame, self-discipline problems</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413787&amp;lang=en</Data></Cell>
</Row>
