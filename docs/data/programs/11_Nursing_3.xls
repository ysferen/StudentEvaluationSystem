<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 170</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Stress Management and Well-Being</Data></Cell>
