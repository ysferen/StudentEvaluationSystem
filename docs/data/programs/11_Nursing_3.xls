<Cell ss:StyleID="Text"><Data ss:Type="String">Career Planning</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">* Explaining career and career related concepts.</Data></Cell>
