<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Psychology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PSI 111</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction to Psychology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Know the basic concepts of psychology as a science, the basic perspectives it contains and the history of psychology in general terms.</Data></Cell>
