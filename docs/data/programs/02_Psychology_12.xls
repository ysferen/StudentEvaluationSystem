<Cell ss:StyleID="Text"><Data ss:Type="String">05.04.2024</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">A chronological presentation of what kind of art music is?</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=325684&amp;lang=en</Data></Cell>
