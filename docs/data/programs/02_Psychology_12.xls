<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Psychology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 158</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Science Reporting and Popular Science Publishing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">05.04.2024</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The course includes theoretical and practical studies necessary to develop the skills of both associate and undergraduate students to read, research and write about scientific topics; to train future science reporters and to increase the scientific culture in our country.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=325812&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Psychology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 159</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of Neuroscience</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">05.04.2024</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">(Neuroscience)</Data></Cell>
