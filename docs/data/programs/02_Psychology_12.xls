<Cell ss:StyleID="Text"><Data ss:Type="String">Psychology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PSI 420</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History and Future of Psychology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Discuss new movements in psychology and their possible future effects and scope.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=325709&amp;lang=en</Data></Cell>
</Row>
