<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Psychology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PSI 323</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Psychology of Learning</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">In addition to being able to define learning as a concept, being able to distinguish between behavioral changes that fall within and do not fall within the scope of learning.</Data></Cell>
