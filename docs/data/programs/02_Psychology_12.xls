<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">23.08.2024</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Conceptual and philosophical foundations of psychology, history, methodology, evolutionary and biological infrastructure, sensation, perception, learning processes and cognitive processes.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=325765&amp;lang=en</Data></Cell>
