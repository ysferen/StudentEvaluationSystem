<Cell ss:StyleID="Text"><Data ss:Type="String">Popular Culture, Media and Communication</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Recognizes the concept of popular culture. Discusses approaches to media and mass communication. Understands the means of dissemination of popular culture. Evaluates the reflections of popular culture in daily life.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=325871&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Psychology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 185</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The Art of Living</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Definition of basic thoughts, importance of rational thinking, putting rational thoughts into action, self-development of individuals, definition of happiness, anxiety, sadness, depression, guilt, shame, self-discipline problems</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=325887&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Psychology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 186</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Change Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The concept of change, importance, scope, objectives, reasons, types, areas subject to change, factors causing organisational change, situations prone to change, dynamic and static organisation, change models, total quality management, bencmarking</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=325874&amp;lang=en</Data></Cell>
</Row>
