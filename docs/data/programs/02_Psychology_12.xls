<Cell ss:StyleID="Text"><Data ss:Type="String">PSI 218</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Research Methods II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Gain Ability to interpret the results of analysis.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=325663&amp;lang=en</Data></Cell>
