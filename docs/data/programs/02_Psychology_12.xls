<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 219</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Theory Of Literature And Criticism</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Approaches the literary text with a critical point of view, finds the underlines and implicit meanings and interprets them.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=325842&amp;lang=en</Data></Cell>
