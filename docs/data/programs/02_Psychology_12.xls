<Cell ss:StyleID="Text"><Data ss:Type="String">ING 201</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English III</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">He/she can understand frequently-used expressions related to the areas of experience most immediately relevant to him/her (e.g. very basic personal and family information, shopping, places of interest, employment, etc.) and communicate.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=325742&amp;lang=en</Data></Cell>
