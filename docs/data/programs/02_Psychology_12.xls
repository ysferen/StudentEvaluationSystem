<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Psychology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ATA 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ataturk&apos;s Principles and History of Revolution I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">05.04.2024</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ottoman and Turkish modernization, the birth of capitalism and industrialization in Europe, imperialism and its effects on the Ottoman Empire, nationalism and nation-states, causes of the collapse of the Ottoman Empire, the 1908 Revolution,The First World War, the struggle for independence and the establishment of a new state, Ataturk’s principles and revolutions are the main topics of this course.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=325691&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Psychology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">FEL 157</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Basic Concepts and Problems in Philosophy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">23.08.2024</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The aim of this course is to introduce philosophy, to teach questioning thought, to teach the development of Human Thought, Culture and to convey the basics of the history of thought. Students, analytical and abstract in this course they learn to think.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=325766&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
