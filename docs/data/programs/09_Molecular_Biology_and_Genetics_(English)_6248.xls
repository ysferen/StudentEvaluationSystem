<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413028&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 141</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction to Gender Equality</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Dersi tamamlayan öğrenci toplumsal cinsiyet eşitliği ve kadın sağlığı hakları için yapılacak faaliyetler konusunda farkındalık sahibi olacaktır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413028&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 142</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of World Culture and Civilisation</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Öğretim Görevlisi tarafından hazırlanacak sunum ve öğrenme çıktıları olarak sunulacaktır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413030&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 143</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ancient Philosophy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Felsefe kavram ve problemlerini tanımlayabilme, edindiği kuramsal bilgileri felsefe problemlerine çözüm geliştirmede ve ortaya konan çözümlerin tartışılmasında kullanabilme becerisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413033&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 143</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ancient Philosophy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Felsefe alanında edindiği kuramsal ve pratiğe dönüştürülebilecek bilgileri; eğitim-öğretim, araştırma ve topluma hizmet alanlarında uygulama becerisi sunacaktır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413033&amp;lang=en</Data></Cell>
</Row>
