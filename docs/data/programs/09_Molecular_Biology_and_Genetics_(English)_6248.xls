<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 136</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Science Communication</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The course includes theoretical knowledge about the role of science communication in the production of science, the full potential of society to ensure the development of science-related communication skills of both associate and undergraduate students, as well as practical studies on the use of science communication tools. Attendance at the lesson is mandatory. As the success of the course will be evaluated according to the results of the practical studies carried out during each course by 80%, the students who will choose the course should take this issue into account.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412948&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
