<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 215</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Human Rights and Health</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Will be able to explain the concept of Human Rights. * Defines the basic concepts related to human rights. * Expresses the importance of Human Rights. * Describe the historical development of Human Rights.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412897&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 215</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Human Rights and Health</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">It will be able to specify international and national legal regulations related to human rights and Human Rights Defenders. * Recognizes legal regulations developed at international and national levels for the protection of Human Rights. * Refers to national and international organizations working on Human Rights. * Discusses how protection mechanisms related to human rights work.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412897&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 215</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Human Rights and Health</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">It will be able to evaluate the practice of Human Rights in different societies and different groups of society and in different environments. * Discusses human rights practices from the point of view of different groups of society. * Interprets the relationship of human rights with development and social inequality. * Questions Human Rights Practices in emergency situations.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412897&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 215</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Human Rights and Health</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Will be able to interpret the relationship between human rights and health. * Evaluates health as a human right. * Examines the use of the right to health by patients and health workers.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412897&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 217</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of Cinema</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">To gain a knowledge of some of the key technological and industrial changes the medium has undergone from 1880-today.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412998&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 217</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of Cinema</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">To understand in greater depth several influential aesthetic and stylistic developments of film.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412998&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 217</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of Cinema</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">To understand how film is an art form (both narrative and non narrative) and an industrial, theatrical, and non theatrical medium.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412998&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 217</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of Cinema</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">To gain an understanding of film as a national, international and global medium.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412998&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 217</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of Cinema</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">To critically engage with select examples of academic writing about film history.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412998&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 221</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of the Horror Film</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">By the end of the course, the students will have a thorough grasp of the history of the horror film, its formal and narrative strategies, and the various critical and theoretical approaches used to examine it.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412861&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 221</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of the Horror Film</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The students will also expand their knowledge of the complex relationship of horror cinema to issues of identity, nation, ideology, and affect.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412861&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 221</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of the Horror Film</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Close analysis of major horror films in class and on exams will make the students a more skilled reader and critic of both cinema and the horror genre.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412861&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 223</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Modern Scientific Research Methods</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Scientific research methods, quantitative and qualitative study examples, data analysis through a statistical program, research results, publication and writing techniques, and reporting.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412843&amp;lang=en</Data></Cell>
</Row>
