<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">A new course flow will be determined each semester based on the current scientific progress determined by the teaching staff and students who teach the course. The courses will progress with students&apos; presentations and joint discussion sessions.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
