<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 031</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Summer Research (20 days)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">02.07.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students do internship for three weeks in research and / or clinical diagnostic laboratories or centers such as universities and hospitals.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412840&amp;lang=en</Data></Cell>
