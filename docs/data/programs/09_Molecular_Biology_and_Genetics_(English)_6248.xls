<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 181</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Civil Society and Volunteering Activities</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Understand the role that NGOs play in our society and the nuances between publicly supported non-profit organizations and public/private foundations.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412915&amp;lang=en</Data></Cell>
</Row>
<Row>
