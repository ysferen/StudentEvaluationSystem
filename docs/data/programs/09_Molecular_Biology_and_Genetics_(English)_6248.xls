<Cell ss:StyleID="Text"><Data ss:Type="String">Bioethics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The Concept of Ethics and the Relationship between Science and Ethics, Basic Principles of Bioethics and Bioethics, Benefit and Non-Harm, Balance of Benefit and Harm, Respect and Consent for Autonomy, Confidentiality and Privacy, Justice in Scientific Research, Vulnerable Groups and Discrimination, Research on People and Ethics, Experiment Animal Research and Ethics, Biotechnology and Bioethics, Scientific Research and Publication Ethics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413017&amp;lang=en</Data></Cell>
