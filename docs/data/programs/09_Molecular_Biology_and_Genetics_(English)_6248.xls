<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 027</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Genomics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Eukaryotic nuclear genomes; prokaryotic and eukaryotic organelle genomes,; viral genomes; mobile genetic elements; acessing genomes; role of DNA binding prote,ns in genome expression; transcriptome; proteome.</Data></Cell>
