<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 110</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">General Biology II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
