<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MBG 026</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Stem Cell and Therapy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Designs an original research project focused on the therapeutic use of stem cells based on a specific biological problem and presents the analysis of the literature review obtained in a scientific manner.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413022&amp;lang=en</Data></Cell>
</Row>
