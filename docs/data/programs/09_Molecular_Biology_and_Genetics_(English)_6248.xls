<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Access to sequence data and necessary basic information, Introduction to pairwise sequence alignment, Introduction to BLAST, Advanced database search, Introduction to multiple sequence alignment, Molecular Phylogeny</Data></Cell>
