<Cell ss:StyleID="Text"><Data ss:Type="String">Molecular Biology and Genetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6248</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ATA 102</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ataturk&apos;s Principles and History of Revolution II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Independence War, founding of the Turkish Grand National Assembly, international treaties, peace process, establishment of the Republic, Ataturk’s principles and revolutions</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=413000&amp;lang=en</Data></Cell>
