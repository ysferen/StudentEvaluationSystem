</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 409</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Drug Metabolism</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Uses drug metabolism information during drug research and development phases.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429757&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 409</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Drug Metabolism</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Gets the necessary information for the identification of drug metabolites.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429757&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 411</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cosmetology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Makes the definition and classification of cosmetic products.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429850&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 411</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cosmetology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Besides cosmetics laws and regulations in Turkey, may explain the legislation in the EU and other countries.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429850&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 411</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cosmetology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explains the anatomy and physiology of skin, skin, skin and all areas where cosmetic products are applied.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429850&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 411</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cosmetology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explains commonly used raw materials and their applications in cosmetics.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429850&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 411</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cosmetology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explains important raw materials and how they are used in cosmetics.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429850&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 411</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cosmetology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explains the basic subjects of cosmetic products and how to use cosmetic products.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429850&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 411</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cosmetology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Knows the legal requirements for the development, production and control of cosmetic products.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429850&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 411</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cosmetology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">To be able to discuss all the information, validations, safety assessment, information required for proof of activity / claim related to raw material and finished product which should be included in content of Cosmetic Product Information File for compliance</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429850&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 413</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cosmetology Lab.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Knows and applies the raw materials used in cosmetic products and their applications in cosmetics.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429639&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 413</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cosmetology Lab.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Knows and applies the subjects related to the formulation development, production methods, and controls of cosmetic products with different structures.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429639&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 413</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cosmetology Lab.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Knows all the information regarding raw materials and finished products that must be included in the Cosmetic Product Information File for regulatory compliance, the quality assurance systems required for compliance with GMP rules, validations, and the information necessary for safety assessment and efficacy/claim substantiation.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429639&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 415</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Pharmaceutical Toxicology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students might be able to explain toxicology, toxic response and dose concept. Describe the role of toxicology in pharmacy practice, drug interactions and adverse effects. Can express that toxicology is a multidisciplinary pharmacy principle and its stakeholder role in risk management with other disciplines.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429684&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 415</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Pharmaceutical Toxicology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Group toxic responses on systems, give examples of toxic agents specific to each system. Explain concepts such as NOAEL, LOAEL, ADI and GRAS.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429684&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 415</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Pharmaceutical Toxicology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Might define the concepts of risk and hazard in terms of toxicology, for the substances exposed to human in daily life and give current examples regarding risk management.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429684&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 415</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Pharmaceutical Toxicology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Might explain how food additives and radioactive substances are evaluated in terms of toxicology.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429684&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 415</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Pharmaceutical Toxicology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students can explain the toxic responses of heavy metals and radiation, their mechanisms of action and treatment methods in detail, and give examples of exposure sources from daily life.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429684&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 471</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Defines clinical pharmacy and patient-oriented concepts. Defines clinical pharmacists&apos; general and specific duties.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429746&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 471</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Understands the importance of systematic approach in patient treatment and approaches the case systematically. Applies the principles of pharmaceutical care. Defines the medication used in treatment and provides patient education.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429746&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 471</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Knows the roles of the pharmacist in the treatment of common cases such as pain and diarrhea and informs the patient.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429746&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 471</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Informs the patient about the rational use of drugs and explains how to use different dosage forms.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429746&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 471</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Prepares patient education materials.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429746&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 473</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy Applications I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Defines the role of pharmacist in hospital wards. Evaluates the file of the patient(s) hospitalized in hospital wards and prepares a case report regarding the patient.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429853&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 473</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy Applications I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Analyze and interpret drugs used by patients in different hospital wards on purpose of use, effects, side effects, drug interactions and other related issues.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429853&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 473</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy Applications I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Describes how inpatient patients should use their medicines.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429853&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 473</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy Applications I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Evaluates the file of a patient in the hospital ward, prepares and presents a case report of the patient.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429853&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 395</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Practical Internship I - Pharmacy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explains general information about the pharmacy where the internship is conducted, and lists key considerations in prescription handling and pharmacist-patient communication</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429764&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 395</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Practical Internship I - Pharmacy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explains the procurement procedures for medicines and medical devices and the records/books that must be kept in the pharmacy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429764&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 395</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Practical Internship I - Pharmacy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Summarizes computer use in the pharmacy, computer-assisted applications, and the pharmacy’s relationship with official institutions and organizations</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429764&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 395</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Practical Internship I - Pharmacy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explains the functions of pharmacists in preventive healthcare services (e.g., family planning, weight management, disease-specific diets, blood pressure monitoring, smoking cessation) and the areas in which they provide health counseling, giving examples. Provides patient education by explaining instructions for the use of dosage forms that require special handling (e.g., inhalers, ophthalmic preparations, insulins) and medical devices</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429764&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 395</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Practical Internship I - Pharmacy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explains patient rights and summarizes what was learned about professional ethical practices</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429764&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 397</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Practical Internship I - Hospital</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explains general information about the hospital pharmacy, lists the practices performed while fulfilling prescriptions and the responsibilities of the pharmacist.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429904&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 397</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Practical Internship I - Hospital</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Gives information about the daily operation of the hospital pharmacy.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429904&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 397</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Practical Internship I - Hospital</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explains the responsibilities of the pharmacist in order to order, prepare and administer drugs in Total Parenteral Nutrition (TPN) and chemotherapy units.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429904&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 397</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Practical Internship I - Hospital</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Describes practices on inspections and drug withdrawals in the hospital pharmacy - adverse effect reporting.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429904&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 397</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Practical Internship I - Hospital</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explain patient rights and summarizes what was learned about professional ethical practices through discussion with the internship supervisor</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429904&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 399</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Applied Internship I - Industry and Institutions</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Describes the workflow in the department where the internship is performed. Explains collaborated wıth which departments (R&amp;D, quality control, production, regulatory affairs, marketing and sales, patent and data protection, etc.), the functions and responsibilities of these departments, and the pharmacist’s place, duties, and responsibilities within this departments.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429901&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 399</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Applied Internship I - Industry and Institutions</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Describes the daily practices in the institution’s relevant department.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429901&amp;lang=en</Data></Cell>
</Row>
