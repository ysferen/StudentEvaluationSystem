<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17.10.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Information about the drug groups described in the course flow, information on laboratory techniques used in quantification of drug active substances.</Data></Cell>
