<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 399</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Elective Applied Internship I - Industry and Institutions</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Describes the activities carried out in the laboratory and/or R&amp;D and/or quality control and production. units</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429901&amp;lang=en</Data></Cell>
</Row>
