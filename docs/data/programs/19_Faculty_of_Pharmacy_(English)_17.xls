<Cell ss:StyleID="Text"><Data ss:Type="String">Managing the change process</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429825&amp;lang=en</Data></Cell>
