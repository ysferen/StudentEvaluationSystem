<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 410</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Pharmaceutical Toxicology II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Express general knowledge and skills about general treatment principles in poisoning. Explain the mechanism of action and treatment method of intoxication due to many easily accessible drugs such as over-the-counter analgesics and anti-inflammatory drugs.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429897&amp;lang=en</Data></Cell>
</Row>
<Row>
