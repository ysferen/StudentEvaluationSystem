<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 303</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Pharmacognosy I Lab</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">0+4+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">20.10.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Theoretical Part: In the courses, the students are informed about the chemical structures, biological effects and uses of natural raw materials, especially herbal drugs.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429726&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
