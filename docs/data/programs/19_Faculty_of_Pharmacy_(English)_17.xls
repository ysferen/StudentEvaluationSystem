<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 547</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Industrial Phytotherapy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">26.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Methods of obtaining plant materials
Isolation of secondary metabolite from plant material
Regulations on plant products
Side effects of herbal drugs interactions with nutrients and other drugs
Plants used as traditional folk medicine
Cosmetics used in plants
Analysis of herbal teas and products
Large scale preparation of herbal preparations</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429699&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
