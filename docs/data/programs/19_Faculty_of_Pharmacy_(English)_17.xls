<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 576</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Social Responsibility Project</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+2+0</Data></Cell>
