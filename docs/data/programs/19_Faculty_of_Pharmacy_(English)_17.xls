<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 410</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Pharmaceutical Toxicology II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students can give information about the exposure sources of volatile poison and alcohol poisoning and explain the treatment approaches.They can provide information about drug groups such as antidepressants, antibiotics, antihistamines and cardiovascular agents, their acute poisoning and their treatment.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429897&amp;lang=en</Data></Cell>
</Row>
