<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 545</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Traditional and Alternative Medicine Systems</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">26.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Theoretical part: General definitions of phytotherapy; legislation and regulation on the subject in the world and Turkey; Bioavailability, pharmacokinetics and pharmacodynamic information about herbal drugs; These risks related to herbal medicines; Based on the results of scientific research, the plants that are useful in the protection and treatment of human health are processed by classification according to the organs they are effective in; Effective components of important plants and their effects.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429697&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
