<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429886&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 139</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Farklı duyguları tanımlar, duyguların işlevlerini öğrenir, kendi duygusunu düzenlemesine destek olacak teknikleri uygular, duygusal zekayı tanımlar ve güçlendirecek pratikleri uygular.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429886&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 139</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
