<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429757&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 409</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Drug Metabolism</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
