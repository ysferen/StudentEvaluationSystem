<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429768&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 472</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Recognizes the pharmacist’s roles in monitoring treatment for chronic diseases such as hypertension, asthma, and diabetes, and provides patient counseling regarding medications and therapy.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429773&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 472</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Defines the roles of the clinical pharmacist in situations frequently requiring pharmacist consultation in the community, such as chronic diseases and pregnancy–lactation periods.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429773&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 472</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Can establish relationships between drugs and diseases and ensures that patients are referred to physicians in a timely manner.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429773&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 474</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy Applications II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Defines the pharmacist’s role in the hospital pharmacy, chemotherapy pharmacy, and total parenteral nutrition preparation unit.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429774&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Faculty of Pharmacy (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">PHAR 474</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Clinical Pharmacy Applications II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Analyzes and interprets the purpose, effect, side effects, drug interactions, and other related aspects of the medications used by patients hospitalized in different hospital departments.</Data></Cell>
