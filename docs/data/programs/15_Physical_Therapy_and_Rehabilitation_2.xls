<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physical Therapy and Rehabilitation</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ATA 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ataturk&apos;s Principles and History of Revolution I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">22.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ottoman and Turkish modernization, the birth of capitalism and industrialization in Europe, imperialism and its effects on the Ottoman Empire, nationalism and nation-states, causes of the collapse of the Ottoman Empire, the 1908 Revolution,The First World War, the struggle for independence and the establishment of a new state, Ataturk’s principles and revolutions are the main topics of this course.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=420885&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physical Therapy and Rehabilitation</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BIL 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction to Computer I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1+2+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">15.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction to Computer: History of Computer, Hardware, Operating Systems, Windows Operating System, Microsoft Office Products, Microsoft Office Word, Microsoft Office Powerpoint, Microsoft Outlook, Internet Research, Working in Different Documents</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=420886&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physical Therapy and Rehabilitation</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">FZT 109</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">15.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Basic concepts related to mechanics, electricity and optics, concepts of heat-temperature and usage areas of heat in medicine, basic concepts of radioactivity and effects of radiation, usage areas of laser and infrared rays in medicine; Chemical bonding and types of chemical bonds in biological macromolecules, extraordinary properties of water and the importance of these properties for life.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=420923&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physical Therapy and Rehabilitation</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">FZT 125</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction to Physiotherapy and Ethic</Data></Cell>
