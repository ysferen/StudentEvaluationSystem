<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">15.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The work of Nobel laureates in Physiology or Medicine and Chemistry will be discussed under the headings Genetics, Gene Regulation, Basic Research, Genome Regulation, Translational Research and Immunity.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=420863&amp;lang=en</Data></Cell>
