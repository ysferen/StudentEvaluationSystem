<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 158</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Science Reporting and Popular Science Publishing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">15.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The course includes theoretical and practical studies necessary to develop the skills of both associate and undergraduate students to read, research and write about scientific topics; to train future science reporters and to increase the scientific culture in our country.</Data></Cell>
