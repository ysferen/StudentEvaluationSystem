<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BIL 102</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction to Computer II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1+2+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">15.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Using Microsoft Excel
Promotion of the Programs Used in the Hospital
Creating Microsoft Access Database Objects Data Types
Microsoft Publisher
Internet Environment, Internet Services, World Wide Web, Web Browsers, Search Engines, File Sharing, Social Networks, Computer Security, Project Development</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=420902&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
