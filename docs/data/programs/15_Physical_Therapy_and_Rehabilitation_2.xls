<Cell ss:StyleID="Text"><Data ss:Type="String">Communication Skills and Presentation Techniques</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">To be in action for the students to get to know each other, to experience get to know you game and to be able to stay in the “moment” by themselves</Data></Cell>
