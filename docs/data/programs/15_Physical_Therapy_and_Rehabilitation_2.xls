<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 172</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Communication Skills and Presentation Techniques</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">What is a presentation, what kinds of presentations are there... Examination of its relationship with communication.
Verbal and literary presentations and spelling mistakes made...</Data></Cell>
