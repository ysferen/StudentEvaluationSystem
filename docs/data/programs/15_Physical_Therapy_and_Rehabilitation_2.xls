<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physical Therapy and Rehabilitation</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">FZT 143</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physiology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">22.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Homeostasis, transport ways through the cell membrane. Membrane and action potentials. Neuromuscular conduction, striated muscle and smooth muscle contraction. Nervous system physiology. Working principles of the heart, EKG. Circulatory system physiology. General properties of blood, its shaped elements. Blood types, hemostasis and coagulation</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=420922&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
