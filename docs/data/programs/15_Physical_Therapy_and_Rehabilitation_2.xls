<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">TUR 102</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Turkish Language II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students acquire the ability to use Turkish correctly, beautifully, effectively, and fluently as a means of written and oral expression.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=420905&amp;lang=en</Data></Cell>
</Row>
