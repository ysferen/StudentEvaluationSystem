<Cell ss:StyleID="Text"><Data ss:Type="String">Physical Therapy and Rehabilitation</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 172</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Communication Skills and Presentation Techniques</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The role of communication and presentation in creating opportunities for advancement in the professional group of the student will be examined.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Practical, verbal, project development</Data></Cell>
