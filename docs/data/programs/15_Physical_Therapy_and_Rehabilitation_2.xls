<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">FZT 128</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biophysics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17.03.2026</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cell membrane structure and functions, membrane and action potentials, action potential in the heart, basic principles of electrocardiography and ultrasonography, viscosity, smooth and swirling flow concepts, hemodynamic principles, respiratory biophysics, biophysical fundamentals of muscle contraction.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=420897&amp;lang=en</Data></Cell>
