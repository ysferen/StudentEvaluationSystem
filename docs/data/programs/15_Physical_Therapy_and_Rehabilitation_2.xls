<Cell ss:StyleID="Text"><Data ss:Type="String">22</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17.03.2026</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">All theoretical and practical courses taken during the undergraduate program must be applied in practice in 3-week-long sessions under the supervision of advisors.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=420802&amp;lang=en</Data></Cell>
