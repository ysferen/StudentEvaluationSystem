<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physical Therapy and Rehabilitation</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 210</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cultural Memory and Photographs</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The photograph as cultural memory- Understanding relation of cultural memory and photographs.</Data></Cell>
