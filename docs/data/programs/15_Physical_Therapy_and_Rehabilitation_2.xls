<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physical Therapy and Rehabilitation</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">FZT 131</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Terminology in Physiotherapy and Rehabilitation</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">13.10.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Plane and axes, Osteoarthritis, Multiple sclerosis, Cerebral palsy, Achilles tendinitis, Chronic obstructive pulmonary disease, Torticollis, Community-based physiotherapy, Hip-knee joint anatomy, Shoulder joint anatomy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=420874&amp;lang=en</Data></Cell>
