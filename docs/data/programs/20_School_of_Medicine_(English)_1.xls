<Cell ss:StyleID="Text"><Data ss:Type="String">Neurology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Diagnose stroke, identify causes of cerebrovascular diseases, take care of acute stroke in emergency room, define cerebrovascular diseases emergencies and be able to refer appropriate patients to specialized tertiary centers</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429069&amp;lang=en</Data></Cell>
