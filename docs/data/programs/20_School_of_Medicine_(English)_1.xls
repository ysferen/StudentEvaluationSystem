<Cell ss:StyleID="Text"><Data ss:Type="String">Obstetrics and Gynecology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Describe urinary incontinence, define basic principles of physical examination of patients with urinary incontinence and summarize their management.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429326&amp;lang=en</Data></Cell>
