</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MED 522</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Biostatistics and Medical Informatics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">14</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Fundamentals of biostatistics and bioformatics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
