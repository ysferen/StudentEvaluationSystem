<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MED 135</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Medical English - I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Lecture 1: No classes – Orientation
Lecture 2: Introduction of the course (Medical English Syllabus)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429292&amp;lang=en</Data></Cell>
