<Cell ss:StyleID="Text"><Data ss:Type="String">13</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Define perimenopausal changes and summarize the management of common conditions of these patients</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429326&amp;lang=en</Data></Cell>
