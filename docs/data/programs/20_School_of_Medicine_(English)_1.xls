<Cell ss:StyleID="Text"><Data ss:Type="String">Oncology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">0+240+0</Data></Cell>
