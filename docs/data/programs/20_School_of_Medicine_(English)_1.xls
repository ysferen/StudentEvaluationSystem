<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MED 134</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Medical English - II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">42+15+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">22.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The course will present authentic medical materials in a variety of formats with the intention of developing high level skills in reading, writing, listening and speaking English as it is used internationally in all the commonly encountered aspects of Medicine, both academic and clinical. Students will be expected to participate individually and in group work.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429293&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
