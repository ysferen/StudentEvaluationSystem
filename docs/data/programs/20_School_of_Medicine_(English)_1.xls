<Cell ss:StyleID="Text"><Data ss:Type="String">Cardiovascular Surgery</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Define symptoms and physical findings of basic congenital heart diseases and timing for intervention and surgery.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429098&amp;lang=en</Data></Cell>
