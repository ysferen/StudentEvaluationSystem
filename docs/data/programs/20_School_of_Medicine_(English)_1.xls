<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MED 405</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cardiovascular Medicine</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Environment/genetic predisposition of the hypercoagulation status 2- how to manage the acute pulmonary embolism and deep venous thrombosis 3- prophylaxis of high risk patient for thrombotic events</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429115&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MED 405</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cardiovascular Medicine</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Define basic mechanisms of cardiac arrhythmias and diagnose basic arrhythmias, 2-Classify the antiarrhythmic drugs according to their action, 3-Define the nonpharmacological treatment options in basic arrhythmias and know the indication of use of these methods 4-Know the medical (acute and chronic treatment) and possible catheter based treatment of basic cardiac arrhythmias,</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429115&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MED 405</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cardiovascular Medicine</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Know cardiopulmonary bypass circuit and how it is used for open heart surgery.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429115&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MED 405</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cardiovascular Medicine</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Define symptoms and physical findings of basic congenital heart diseases and timing for intervention and surgery.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429115&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MED 406</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Surgery</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">General Surgery • be familiar to the anatomy of surgical sites • describe the symptoms and physical findings of patients with surgical disease, , • analyze the signs and symptoms in a patient • outline the principles of managing surgical patients (acute abdomen, hemodynamic instability, hemorogie, etc)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429276&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MED 406</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Surgery</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">differentiate between benign and malignant/ acute and chronic/ emergent and elective surgical disease.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429276&amp;lang=en</Data></Cell>
</Row>
