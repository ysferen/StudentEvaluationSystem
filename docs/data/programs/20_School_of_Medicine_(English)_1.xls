<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 217</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History Of Cinema</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Hollywood and Its Rise to Dominance: Advent of Sound, the Formation of the Studios and The Star System
Films: Alan Crosland, U.S., The Jazz Singer (1927)
Victor Fleming, U.S., The Wizard of Oz (1939)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429298&amp;lang=en</Data></Cell>
</Row>
