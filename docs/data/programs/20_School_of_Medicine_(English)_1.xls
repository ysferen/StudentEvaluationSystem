<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">27.03.2026</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Theoretical and practical courses: multimedia sessions, role play, peer discussions, plenary sessions with student presentations, lectures, reading and listening comprehension exercises of simple medical conversations and basic texts, analyses of simple medical texts (popular media, general health information leaflets etc.)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429292&amp;lang=en</Data></Cell>
