<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 230</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Good Manufacturing Practices (GMP) - Good Laboratory Practices (GLP)</Data></Cell>
