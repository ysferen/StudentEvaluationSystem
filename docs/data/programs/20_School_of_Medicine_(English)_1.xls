<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Hastanın bütünlüğünü dikkate alarak, yüksek nitelikli sağlık bakımı sunar</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sağlık hizmet sunumunda, hizmet verdiği toplumun sosyoekonomik ve kültürel özelliklerini dikkate alır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sağlık hizmeti sunarken hasta güvenliği ve klinik çıktıları dikkate alır ve uygulamalarına yansıtır</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Temel ve klinik tıp bilimlerinin ilkelerini, bilimsel bilgisini ve yöntemlerini bütünleştirerek kullanır</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sosyal ve davranış bilimlerinin ilkelerini, bilimsel bilgisini ve yöntemlerini bütünleştirerek kullanır</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Toplum sağlığının ilkeleri ve yöntemlerini kullanarak toplumun ve bireylerin sağlığını korur ve geliştirir</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Hastalar, hasta yakınları ve sağlık çalışanları ve diğer meslek grupları ile yazılı ve sözlü etkin iletişim kurar</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sağlık hizmeti, araştırması ve eğitimine yönelik çalışmalarının etkinliğini artırmak için güncel tıbbi teknolojileri akılcı ve etkin olarak kullanır</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Hizmet verdiği toplumun özelliklerini, ihtiyaçlarını ve beklentilerini tanıyarak, sağlıklı/hasta bireylere ve yakınlarına ve diğer sağlık çalışanlarına sağlık eğitimi ve danışmanlık verir.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Tıbbi uygulamalarında ve araştırmalarında etik ve profesyonel ilkelere bağlılık gösterir</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Hasta haklarına, onuruna, özerkliğine, bütünselliği ve gizliliğine saygı gösterir</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">13</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Hastalarına ve topluma karşı eşitlikçi, çeşitliliğe saygılı ve ayrımcı olmayan bir tutum içinde olur</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">14</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Etik ikilemleri fark eder ve mesleki etik ilkeler ile yönetir</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">15</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Mesleği ile ilişkili ulusal ve uluslararası mevzuatın farkındadır ve uygulamalarında gözetir</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">16</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sahip olduğu yeterliklerin ve sınırlılıklarının farkındadır, buna uygun davranır ve gerekli durumlarda yardım ister</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">17</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Gelişmeye ihtiyaç duyduğu alanların farkındadır ve yaşam boyu öğrenme yoluyla mesleki faaliyetlerini geliştirir</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">18</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Kendi fiziksel ve ruhsal iyilik halini önemser, korumak ve geliştirmek için çalışır</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">19</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Mesleki gelişimini sürdürebilmek için kariyer hedeflerini belirler ve bu hedeflere ulaşmak için kariyerini bilinçli bir şekilde yönlendirir.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">20</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Kendisinin ve meslektaşlarının çalışma ve özlük haklarının farkındadır ve geliştirilmesi için sorumluluk alır ve savunuculuğunu yapar</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">21</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Çalışma ortamında kendisinin ve diğer çalışanların sağlığını ve iş güvenliğini gözeterek hizmet sunar.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">22</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sağlık uygulamalarında toplum sağlığını ve sürdürülebilir sağlık hizmeti ilkelerini esas alarak yöntemleri ve bilgileri etkin bir şekilde uygular.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">23</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Bilimsel bilgiye sahip çıkar; bilimsel yaklaşımların ve kanıta dayalı uygulamaların savunuculuğunu yapar ve kişi ve toplum yararına kullanır</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">24</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Uygulamalarında bilimsel kanıtları kullanabilmek için tıbbi literatürün eleştirel değerlendirmesini yapar</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">25</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Bir bilimsel araştırma planlayabilir, uygulayabilir ve sonuçlarını paylaşabilir</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">26</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Bireylerin sağlıklı olma ve sağlık hizmetlerine ulaşabilme hakkının farkındadır, hak ihlallerini ve ortaya çıkaran koşulları tanır ve giderilmesi için çalışır</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">27</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sağlığın sosyal belirleyicilerini, sağlığı etkileyebilecek çevresel, sosyal, ekonomik ve kültürel faktörleri değerlendirir ve kişi ve toplum yararına uygulanabilir çözümler üretir</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">28</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Hizmet sunduğu toplumun beklentileri ve öncelikli gereksinimlerinin farkındadır ve karşılanması için toplumsal sorumluluk ile çalışır ve savunuculuk yapar</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">29</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sağlık hizmetinde savunmasız grupları önemser, öncelik verir ve korur</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">30</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ekolojik sürdürülebilirlik ve iklim değişikliği alanlarında farkındalık geliştirir, liderlik yapar ve bu ilkeleri mesleki uygulamalarına taşır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">31</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Diğer hekimler ve farklı disiplin ve mesleklerden kişilerle etkin bir şekilde veişbirliği içinde çalışır</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">32</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sağlık hizmeti süreçlerinin yönetiminde sorumluluk alır, öncülük eder, kişiler ve topluluklar arasındaki farklılıkları gözeten, eşitlikçi, dürüst ve tutarlı bir yaklaşım belirler.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">33</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sağlık uygulamaları sırasında oluşabilecek krizleri ve belirsizlikleri etkin olarak yönetir</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">School of Medicine (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">34</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Yöneticisi olduğu sağlık kuruluşunda, sağlık hizmetlerini planlama, uygulama, değerlendirme süreçlerinde kaynakları maliyet-etkin,toplum yararına ve mevzuata uygunkullanır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=1</Data></Cell>
</Row>
</Table>
