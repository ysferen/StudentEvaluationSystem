<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MED 5540</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">General Surgery</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">describe the basic principles of oxygen therapy and mechanical ventilation.</Data></Cell>
