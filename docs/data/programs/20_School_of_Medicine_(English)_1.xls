<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MED 406</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Surgery</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Thoracic Surgery • learn basic principles of chest tube insertion • management of chest trauma patient. • differantiate main thoracic surgical pathologies and know their treatment. • define radiological findings of main thoracic surgical pathologies.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429276&amp;lang=en</Data></Cell>
</Row>
<Row>
