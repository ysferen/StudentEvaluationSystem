<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 231</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Award-Winning Topics in Molecular Biology and Genetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">22.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The work of Nobel laureates in Physiology or Medicine and Chemistry will be discussed under the headings Genetics, Gene Regulation, Basic Research, Genome Regulation, Translational Research and Immunity.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=429161&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
