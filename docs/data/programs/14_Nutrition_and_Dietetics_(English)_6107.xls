<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 115</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physiology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">19.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cell Physiology, Nerve Physiology, Blood Physiology Circulatory Physiology Respiratory System Digestive System Excretory Physiology Nov Physiology, Metabolism, Physiology, Endocrine Physiology, Sensory Physiology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422233&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
