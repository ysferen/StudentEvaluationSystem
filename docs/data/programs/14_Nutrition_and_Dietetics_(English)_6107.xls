<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422323&amp;lang=en</Data></Cell>
