<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 210</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Food and Nutrition</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">She/he will be able to discuss the relationship between foods and nutrition using scientific literature.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422286&amp;lang=en</Data></Cell>
</Row>
