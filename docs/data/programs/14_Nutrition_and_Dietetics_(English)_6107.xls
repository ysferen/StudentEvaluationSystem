<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 233</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Accessing Evidence-Based Information and Academic Writing Skills</Data></Cell>
