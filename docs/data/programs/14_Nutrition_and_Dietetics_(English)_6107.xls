<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 233</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Accessing Evidence-Based Information and Academic Writing Skills</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Using the PICO approach, she/he is able to conduct a database search on the topic of interest.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422238&amp;lang=en</Data></Cell>
</Row>
