<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 221</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The Horror Film</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Found-footage films (1990’s – 2000’s)
Film: The Blair Witch Project (E. Sanchez &amp; D. Myrick, 1996)</Data></Cell>
