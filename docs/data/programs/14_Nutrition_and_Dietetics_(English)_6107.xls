<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 123</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Orientation of Profession and Ethics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11.11.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction to nutrition and dietetics department and , teaching professional ethics and deontology, regulations and student responsibilities, practices related to Dietetics profession, introduction to standards and professional organization, introduction of Professional Associations and international associations, introduction of basic sources related to their profession and transportation routes.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422302&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 125</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Basic Chemistry I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+2+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">19.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Form and matter, atomic structure, periodic table, chemical compounds, chemical reactions, Stoichiometry, chemical reactions, gases, liquids, solids, solutions, solubility, acids and bases, oxidation and reduction, Biochemistry, introduction to organic chemistry.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422303&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
