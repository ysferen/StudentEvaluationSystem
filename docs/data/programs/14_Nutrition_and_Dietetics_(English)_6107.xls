<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 370</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Communication Skills</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">19.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">It includes a definition of elements and features of effective interpersonal communication: language used, self-knowledge, effective listening and feedback, factors preventing and facilitating communication, persuasive communication, the role and use of emotions in communication, effective communication techniques, conflict in communication, nonverbal communication skills, and rules of behavior in social life. It also covers the topics of etiquette, courtesy, and professional communication practices.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422325&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">MIS 318</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Research Methods</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">19.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Research planning and execution</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422407&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 401</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Vocational Training in Clinical Nutrition-Children</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">0+18+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">19.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The course contributes to the integration of theoretical and applied knowledge of the field and outside the field, and to gain the knowledge, skills and competencies required for the planning of the nutritional care process and its implementation within the framework of ethical principles.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422308&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 403</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Vocational Training in Clinical Nutrition-Adult</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">0+18+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">27.04.2026</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The course contributes to the integration of theoretical and applied knowledge of the field and outside the field, and to gain the knowledge, skills and competencies required for the planning of the nutritional care process and its implementation within the framework of ethical principles.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422309&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 405</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics-Community Health</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">0+22+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11.11.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The scope of the course includes vocational orientation, assessment of nutritional status in the community and the use of assessment methods. In line with the target, it is aimed that students continue their personal development by transferring the theoretical knowledge they have acquired into practice, improve their right decision making skills, and gain experience on the job. In line with these objectives, the course is evaluated with oral presentation and research / graduation project methods. The midterm exam will have a contribution of 40% and the final exam will have a contribution of 60%. Within the scope of the midterm exam, students develop educational material targeting nutritional problems in the society and present it as a presentation. For the final evaluation, a research project is expected to be prepared within the scope of this problem.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422310&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 465</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Seminar I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.11.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Researching, evaluating, discussing and presenting the latest scientific data about nutrition and dietetics and reporting and presenting the compiled information.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422292&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 467</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Professional Projects I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.11.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The course is based on the student&apos;s theoretical knowledge and research skills acquired in undergraduate education. The course makes a significant contribution to the acquisition of knowledge, skills and competencies required for graduation. The course will be conducted in a distance education environment. Therefore, it will be carried out with teaching methods suitable for online education, personal independent learning, question-answer and brainstorming practices. Research shows that when students learn the material in an active learning environment, they understand the material at a deeper level and thus retain it for a longer period of time. In order to facilitate the active learning component of the course, personal independent learning, question-answer and brainstorming learning activities will be included.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422289&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 429</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition of Ageing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11.11.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Definition and importance of old age, problems encountered in old age with nutritional therapy, common diseases in old age,</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422408&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 431</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Food Intolerance and Allergy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11.11.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">It includes Food allergy epidemiology, definition and classification of food allergies, methods used to determine food allergy, atopic dermatitis, urticaria and angioedema, respiratory system and allergies and eosinophilic gastroenteritis.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422409&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 433</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Prebiotics and Probiotics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">27.04.2026</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Prebiotics, probiotics and synbiotics in disease and health</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422410&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 447</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Bariatric Surgery and Nutritional Therapy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">19.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Includes these topics: History of bariatric surgery, indications, contraindications and importance of the team, bariatric surgery methods, regulation of macronutrient elements, evaluation and monitoring of the patient&apos;s nutritional status in bariatric surgery before and after surgery, planning nutritional support programs according to bariatric surgery methods, evaluation of nutritional deficiencies in bariatric surgery methods, bariatric surgery Evaluation of metabolic complications in bariatric surgery methods, evaluation of dietary complications in bariatric surgery methods, monitoring of nutritional status after bariatric surgery, monitoring of metabolic status after bariatric surgery, evaluation of bariatric surgery in metabolic diseases, weight maintenance and management after bariatric surgery, planning and maintenance of medical nutrition therapy after bariatric surgery.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422411&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NUT 449</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Health Communication in Media</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12.11.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Media and Social Media (with Concepts and Subtitles)
Global Media and Social Media Usage Reports
Health and Nutrition Communication
Health and Nutrition Communication in the Media
The Role of Dietitians in the Media, International Practices
Ethics in Media and Social Media
Health Campaign Development Application</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=422290&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
