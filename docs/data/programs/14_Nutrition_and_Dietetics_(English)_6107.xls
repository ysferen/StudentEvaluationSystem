<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">19.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">DNA replication, transcription, translation, genotype-phenotype-cell identity relationship, gene-basic disease relationships, foundations of heredity, molecular medicine, epigenetics and nutrigenetics in nutrition</Data></Cell>
