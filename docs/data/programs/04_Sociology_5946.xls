<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 209</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Musics of The World’s Cultures</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Recognize the musical systems and instruments,</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131975&amp;lang=en</Data></Cell>
</Row>
<Row>
