<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 208</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of Thought</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Realize that a individual&apos;s thought is historically and socially constructed.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131922&amp;lang=en</Data></Cell>
</Row>
