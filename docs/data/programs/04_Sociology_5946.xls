<Cell ss:StyleID="Text"><Data ss:Type="String">Science Communication</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Bilim iletişimcilerinin ahlaklı ve saygılı olmakla ilgili sorumluluk gerektiren davranışlarının neler olduğu konusunda bilgi sahibi olur</Data></Cell>
