<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">29.08.2019</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">It includes the types of written and oral expression, the process of scientific research, and the subjects of referring that need to be considered in oral presentations.</Data></Cell>
