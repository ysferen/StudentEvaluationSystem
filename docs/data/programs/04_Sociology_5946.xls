<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131975&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 210</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Cultural Memory and Photographs</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students who complete the course will be able to conceptually recognize cultural memory and photography independently. In addition, they will be able to analyze how cultural memory and family photographs feed each other; what family photography reflects or wants to reflect on us through concepts such as remembering, forgetting, nostalgia.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131974&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 211</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Understanding Everday Life Practices of Turkey</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Will be able to understand the meaning of everyday practices; talking, reading, moving about, shopping, cooking ets.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131985&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 211</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Understanding Everday Life Practices of Turkey</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The focus of the lecture would be everyday life of Turkey. Lecture will be conducted with the examples reflecting culture fragments from Turkey. The students would gain the ability to understand and analyse their own life and Turkey.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131985&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 211</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Understanding Everday Life Practices of Turkey</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explain and analyse the politics of daily routines.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131985&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 211</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Understanding Everday Life Practices of Turkey</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Would be able to write a paper and make a presentation about the issue.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131985&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 211</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Understanding Everday Life Practices of Turkey</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Would be able to analyse the preferences of their own life practices. Who made the choices in reality?</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131985&amp;lang=en</Data></Cell>
</Row>
