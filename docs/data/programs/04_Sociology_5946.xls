<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ING 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English IV</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">He/she can interact provided the other person talks slowly and clearly and is prepared to cooperate.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131900&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ING 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English IV</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">He/she can understand frequently-used expressions related to the areas of experience most immediately relevant to him/her (e.g. very basic personal and family information, shopping, places of interest, employment, etc.) and communicate.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131900&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ING 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English IV</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">He/she can talk about personal and professional future plans.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131900&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ING 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English IV</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">He/she can listen and understand simple presentations.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131900&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ING 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English IV</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">He/she can talk about a film or a book and can write a short paragraph about it.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131900&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ING 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English IV</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">He/she can understand short reading texts, summarize and write a report.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131900&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SOS 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Research Methods II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explain and discuss the philosophical background of the return to qualitative method in the Social Sciences.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131958&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SOS 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Research Methods II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explain the main differences between quantitative and qualitative methods and in what contexts each can be used.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131958&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SOS 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Research Methods II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explain and discuss qualitative research patterns and data generation techniques.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131958&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SOS 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Research Methods II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explain and discuss the main approaches to qualitative data analysis and technical principles related to data series and analysis.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131958&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SOS 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Research Methods II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Explain and discuss ethical and political considerations specific to qualitative research.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131958&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SOS 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Research Methods II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Design a qualitative research.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131958&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SOS 202</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Research Methods II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Know and discuss the main differences between qualitative and quantitative research reports.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131958&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SOS 212</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociological Theory I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">To understand the historical and social contexts in and through which the classical sociological theories developed</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131960&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SOS 212</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociological Theory I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">To describe the main concepts of the classical thinkers</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131960&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SOS 212</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociological Theory I</Data></Cell>
