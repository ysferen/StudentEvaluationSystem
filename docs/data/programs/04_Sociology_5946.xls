<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 136</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Science Communication</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Etkin bir şekilde grup çalışmalarına katılarak eleştirebilen ve eleştirilebilen bireyler halinde, iletişim ile ilgili özgüvenlerini arttırır</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131983&amp;lang=en</Data></Cell>
</Row>
