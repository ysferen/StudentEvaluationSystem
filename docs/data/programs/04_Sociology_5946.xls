<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sociology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5946</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SOS 132</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Basic Academic Skills</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">31.03.2021</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">This course consists of presentation of the basic academic skills to students, their demonstration by examples and the works of students to expose these skills.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=131860&amp;lang=en</Data></Cell>
