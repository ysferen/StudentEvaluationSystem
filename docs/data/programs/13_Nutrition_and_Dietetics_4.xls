<Cell ss:StyleID="Text"><Data ss:Type="String">ING 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">They can leave or respond to simple messages following phone calls, understand short videos or listening texts on this topic, and engage in related spoken interactions.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421924&amp;lang=en</Data></Cell>
</Row>
