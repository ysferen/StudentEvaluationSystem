<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Have an idea about the general nutritional recommendations given for different age groups and physiological situations.</Data></Cell>
