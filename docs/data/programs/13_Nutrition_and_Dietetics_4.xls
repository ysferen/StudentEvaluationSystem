<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 124</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutritional Anthropology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">She/he is able to create menu examples specific to Turkish and world cuisines.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421790&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 124</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutritional Anthropology</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">She/he is able to compare the nutritional habits of societies within the framework of healthy nutrition.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421790&amp;lang=en</Data></Cell>
</Row>
