<Cell ss:StyleID="Text"><Data ss:Type="String">English I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students will be able to describe themselves and people around them using simple adjectives, ask and answer basic questions to exchange personal information, and engage in short conversations.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421924&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ING 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students will be able to read simple texts about study habits and professions, and ask and answer related questions orally or in writing.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421924&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ING 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students are capable of describing family members and relationships, as well as daily routines — both their own and others’ — through written and spoken communication. They also comprehend short reading passages on these topics.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421924&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ING 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">They can ask and respond to questions involving time and place, and engage in simple conversations with peers and family members to arrange meetings or social gatherings.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421924&amp;lang=en</Data></Cell>
</Row>
