<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 440</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Dietary Supplements and Functional Foods</Data></Cell>
