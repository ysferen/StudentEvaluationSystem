<Cell ss:StyleID="Text"><Data ss:Type="String">English I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">They can interpret videos about giving and following directions, ask and answer questions about places and routes, and take part in short dialogues based on these topics.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421924&amp;lang=en</Data></Cell>
