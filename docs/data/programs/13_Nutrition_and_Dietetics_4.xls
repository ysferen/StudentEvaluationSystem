<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 403</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English for Specific Purposes I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">They can apply basic grammatical structures — including the passive voice and relative clauses — accurately in both written and spoken tasks related to food science.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421843&amp;lang=en</Data></Cell>
</Row>
