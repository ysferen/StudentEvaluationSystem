<Cell ss:StyleID="Text"><Data ss:Type="String">History of Cinema</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">World Cinema Beyond the West: European/ Asian/ Latin American (50’s – 60’s)
