<Cell ss:StyleID="Text"><Data ss:Type="String">Anatomy II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">They will be able to explain the anatomy of systems.</Data></Cell>
