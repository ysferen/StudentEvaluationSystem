<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Know the nutrients necessary for life, sort the food sources and express their importance in the body&apos;s work.</Data></Cell>
