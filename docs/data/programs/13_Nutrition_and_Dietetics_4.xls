<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 221</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of the Horror Film</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Master of Suspense: Hitchcockian Horror (1950’s – 1960’s)
Film: Psycho (Alfred Hitchcock, 1960)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Lecturing</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421785&amp;lang=en</Data></Cell>
