<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ING 101</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">They will be able to describe objects and their locations using appropriate adjectives, and produce short written texts about their room, house, or other familiar environments.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421924&amp;lang=en</Data></Cell>
</Row>
