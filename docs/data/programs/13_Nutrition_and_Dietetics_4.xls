<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">19.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Classification of hereditary metabolic diseases, diagnostic methods, incidence, complications, interpretation of clinical and laboratory findings, medical treatment methods of hereditary metabolic diseases, nutritional therapy methods of hereditary metabolic diseases</Data></Cell>
