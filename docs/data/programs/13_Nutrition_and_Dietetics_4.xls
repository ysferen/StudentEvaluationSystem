<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">19.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The course contributes to the integration of information about nutrition in emergency situations and the acquisition of this knowledge, skills and competencies.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421915&amp;lang=en</Data></Cell>
