<Cell ss:StyleID="Text"><Data ss:Type="String">BES 464</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Carbohydrate Counting</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
