<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 445</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Vocational Training in Community Nutrition</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students will be able to define the methods of determining the nutritional status and eating habits of the society.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421917&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 445</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Vocational Training in Community Nutrition</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">They can improve the ability to give nutrition education to individuals and to communicate correctly.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421917&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 445</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Vocational Training in Community Nutrition</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students can develop nutrition education materials and programs for different groups in society and nutritional problems.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421917&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 445</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Vocational Training in Community Nutrition</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students can work as a team with health professionals working in the field of public health with their knowledge, skills and abilities.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421917&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 445</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Vocational Training in Community Nutrition</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">They can define the stages of research planning, data collection and evaluation.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421917&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 445</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Vocational Training in Community Nutrition</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">They can interpret by comparing their data with literature information.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421917&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 445</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Vocational Training in Community Nutrition</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">They can prepare education programs to increase the awareness of the society in order to prevent nutrition-related diseases.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421917&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 445</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Vocational Training in Community Nutrition</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">They can develop solutions for the nutrition problems of the society.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421917&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 449</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Professional Projects I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">He/She is able to explain the characteristics of scientific litterature and academic databases suitable for academic writing.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=421892&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nutrition and Dietetics</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">BES 449</Data></Cell>
