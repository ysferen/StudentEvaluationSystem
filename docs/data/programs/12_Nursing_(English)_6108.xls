<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414312&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 213</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English Language Course For Erasmus I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students will be able to write a factual summary.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414312&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 213</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English Language Course For Erasmus I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students will be able to respond to questions on familiar and unfamiliar topics and to speak at length.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414312&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 213</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">English Language Course For Erasmus I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Academic vocabulary will be targeted; students will be able to use high-level vocabulary.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414312&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 215</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Human Rights and Health</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Will be able to explain the concept of Human Rights. * Defines the basic concepts related to human rights. * Expresses the importance of Human Rights. * Describe the historical development of Human Rights.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414315&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 215</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Human Rights and Health</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">It will be able to specify international and national legal regulations related to human rights and Human Rights Defenders. * Recognizes legal regulations developed at international and national levels for the protection of Human Rights. * Refers to national and international organizations working on Human Rights. * Discusses how protection mechanisms related to human rights work.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414315&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 215</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Human Rights and Health</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">It will be able to evaluate the practice of Human Rights in different societies and different groups of society and in different environments. * Discusses human rights practices from the point of view of different groups of society. * Interprets the relationship of human rights with development and social inequality. * Questions Human Rights Practices in emergency situations.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414315&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 215</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Human Rights and Health</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Will be able to interpret the relationship between human rights and health. * Evaluates health as a human right. * Examines the use of the right to health by patients and health workers.</Data></Cell>
