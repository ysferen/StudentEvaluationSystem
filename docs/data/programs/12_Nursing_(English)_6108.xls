<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NRS 110</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Anatomy II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1+2+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">25.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">To develop student&apos;s self-learning ability, to cover basic anatomy knowledge</Data></Cell>
