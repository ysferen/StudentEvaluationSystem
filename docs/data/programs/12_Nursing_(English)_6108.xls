<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 218</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Gender And Literature</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Starts a discussion about the important works of World Literature, makes analysis and synthesis, examines the socio-cultural infrastructure according to gender roles.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414359&amp;lang=en</Data></Cell>
