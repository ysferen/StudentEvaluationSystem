<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 217</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History Of Cinema</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Hollywood and Its Rise to Dominance: Advent of Sound, the Formation of the Studios and The Star System
Films: Alan Crosland, U.S., The Jazz Singer (1927)
Victor Fleming, U.S., The Wizard of Oz (1939)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414314&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 217</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History Of Cinema</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">More on Hollywood: The Studio System and Exceptional Auteurs (1930-1945)
Genre development
Films: Michael Curtiz, U.S, Casablanca (1942).
Orson Welles, U.S., Citizen Kane (1941).
Alfred Hitchcock, U.S., Rebecca (1940).</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414314&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 217</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History Of Cinema</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Wartime and Postwar Cinema: German Nationalist/ Italian Neorealism/ American Censorship and Blacklists
Film and social engineering (post-war U.S.)
Outside the system
Films: Leni Riefenstahl, Germany, The Triumph of the Will (1935)
Vittorio De Sica, Italy, The Bicycle Thieves (1948).
Herbert Biberman, U.S., The Salt of the Earth (1954).</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414314&amp;lang=en</Data></Cell>
</Row>
