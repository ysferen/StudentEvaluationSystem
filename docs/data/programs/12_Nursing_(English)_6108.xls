<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NRS 108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physiology II</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">25.06.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">It contributes to the understanding of the basic functioning principles of the human body, the working mechanisms of physiological systems and organs and their anatomical and physiological relationships with each other.</Data></Cell>
