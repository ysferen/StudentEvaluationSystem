<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NRS 105</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Anatomy I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Describe the blood vessels supplying and the nerves innervating the organs of the digestive system.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414206&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NRS 107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physiology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students will be able to define the concept of homeostasis, explain the body&apos;s basic homeostatic functional systems, and describe the structure and components of biological membranes.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414207&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NRS 107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physiology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students will be able to explain the resting membrane potential and describe the formation process and stages of the action potential in detail.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414207&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NRS 107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physiology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students will be able explain the physiological mechanism of muscle contraction.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414207&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NRS 107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physiology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students will be able to identify the basic parts of the central and peripheral nervous systems and explain their functions.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414207&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nursing (English)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6108</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">NRS 107</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Physiology I</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Students will be able to identify neurotransmitters and synapses and explain the fundamental mechanisms that regulate neurotransmission.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=414207&amp;lang=en</Data></Cell>
