    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 178</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Modern Scientific Research Methods</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">To be able to understand the basic principles and processes in the realization of research, To learn different research methods, To be able to analyze data and develop solutions, and to interpret the results obtained with the help of software.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412063&amp;lang=en</Data></Cell>
   </Row>
