    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">To be able to consider the basic knowledge about matter and materials gained in this course according to applicability in medical structure and systems</Data></Cell>
