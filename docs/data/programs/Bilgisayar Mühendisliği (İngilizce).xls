    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 509</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Biomedical Signal Processing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Discrete versus continuous-time signals, Sampling theorem, Pre-filtering, Down-sampling</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String"></Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String"></Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412011&amp;lang=en</Data></Cell>
