   <Row ss:Height="135">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">MBG 024</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Biophysics</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3+0+0</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">7</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">24.06.2025</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Teaching Method: Lecture in the form of lectures, question-answer, group homework, slide Introduction to biophysics and atom, molecule, matter; concepts of radioactivity, communication of radiation with matter, biological effects; water and aqueous solutions as living environment; osmosis, dialysis, surface tension; structure and functions of cell membrane; membrane proteins, channel channels; material transport across biological membranes; structure and functions of biomolecules; energy flow in living things, thermodynamic laws, thermodynamic properties of water; ATP and chemical energy transmission; cell breathing; free energy change of electron transfer chain; bioelectric potentials and biophysical bases of muscle contraction; biomechanics; bioenergetic properties of muscle contraction; heart muscle and smooth muscle; It covers communication biophysics and biophysical research methods.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411966&amp;lang=en</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">OK</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String"></Data></Cell>
   </Row>
