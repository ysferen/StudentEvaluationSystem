    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 217</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">History of Cinema</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Origins: Preconditions for the “movies” Silent Films and the Narrative in Films Who invented movies? (Selected “players”) Films: Thomas Edison Program: Sandow The Strong Man (1894) Edwin S. Porter Program: Great Train Robbery (1903) Georges Méliès, Trip to the Moon (1902)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String"></Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String"></Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412030&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="45">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 217</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">History of Cinema</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Intro to European Movements: 1920’s German Expressionism, Soviet Montage, and French Impressionism Films: Robert Wiene, German, The Cabinet of Dr. Caligari (1919) Sergei Eisenstein, Soviet Union, [The Battleship] Potemkin (1925) Luis Buñuel &amp; Salvador Dali, France, Un Chien Andalou (Andalusian Dog) (1927) Impressionism</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String"></Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String"></Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412030&amp;lang=en</Data></Cell>
   </Row>
