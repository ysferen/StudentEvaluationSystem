    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 308</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Theories of Personality</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">define the view of humanistic approaches to personality.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411908&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 308</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Theories of Personality</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">7</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">compare the views of different theorists in the humanistic approach in terms of the nature, functioning of personality and perspectives on psychopathology.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411908&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 310</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Introduction to Evolutionary Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">explain the emergence and purpose of evolutionary psychology.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412008&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 310</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Introduction to Evolutionary Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">explain how mental modules are formed and function.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412008&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 310</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Introduction to Evolutionary Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">explain the criticisms directed towards evolutionary psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412008&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 310</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Introduction to Evolutionary Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">discuss the future of evolutionary psychology.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412008&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 313</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Forensic Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Have information about the history of Forensic Psychology, the duties of forensic psychologists and the process of becoming a forensic psychologist.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412009&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 313</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Forensic Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">By learning the views of different disciplines on why people are involved in crime, they have a comprehensive understanding of the individual and environmental causes of criminality.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412009&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 313</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Forensic Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Learn about current and applied studies of forensic psychology, such as profiling, eyewitness, deception detection</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412009&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 313</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Forensic Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">By acquiring information about criminal risk assessment, interviewing criminals, intervention programs, they understand the work carried out to reintroduce a person involved in crime to society.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412009&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 313</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Forensic Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Learn about the neglected aspect of the crime phenomenon, how victims are affected by the crime, theoretical opinions on this issue, and intervention studies.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412009&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 313</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Forensic Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Have information about the practice of Forensic Psychology in Turkey.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412009&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 321</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Psychology of Language</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Summarize the scope and methodology of the field of language psychology and the basic components of language proficiency.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411832&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 321</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Psychology of Language</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Describe the biological foundations of language, language development and language disorders.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411832&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 321</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Psychology of Language</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Explain speech production and speech comprehension processes.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411832&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 321</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Psychology of Language</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">describe discussions and discussions about gestures, sign language, and the subject of language and thought.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411832&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 321</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Psychology of Language</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Evaluate a study in the field of language psychology in the light of the findings of other research and more general discussions in the field, such as naturalism and empiricism.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411832&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 323</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Learning Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Kavram olarak öğrenmeyi tanımlayabilmenin dışında, öğrenmenin kapsamına giren ve girmeyen davranış değişikliklerini ayırt edebilme.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411909&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 323</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Learning Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Tek uyaranı öğrenmenin biyolojik işlevini, mekanizmasını ve nörolojik temellerini açıklayabilme.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411909&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 323</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Learning Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Klasik koşullanmanın mekanizmasını ve nörolojik temellerini açıklayabilme, patolojik davranışla bağlantısını açıklayabilme.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411909&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 323</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Learning Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Klasik koşullanmanın mekanizması üzerine öne sürülmüş olan farklı görüşleri açıklayabilme, eleştirebilme.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411909&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 323</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Learning Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Edimsel koşullanmanın klasik koşullanmadan farkını, mekanizmasını, davranışı şekillendirmede ve değiştirmedeki rolünü açıklayabilme.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411909&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PSY 323</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Learning Psychology</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Edimsel koşullanmanın etki mekanizması üzerine öne sürülmüş olan farklı görüşleri açıklayabilme ve eleştirebilme.</Data></Cell>
