    <Cell ss:StyleID="s63"><Data ss:Type="String">Biomedical Signal Processing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">10</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Harmonic analysis - estimation of heart rate in ECG, heart rate monitoring, pitch detection</Data></Cell>
