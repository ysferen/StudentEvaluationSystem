    <Cell ss:StyleID="s63"><Data ss:Type="String">24.06.2025</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Definition of happiness, ways to be happy, self-knowledge</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411970&amp;lang=en</Data></Cell>
