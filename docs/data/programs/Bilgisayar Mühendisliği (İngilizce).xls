   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 196</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Teaching Turkish to Foreigners</Data></Cell>
