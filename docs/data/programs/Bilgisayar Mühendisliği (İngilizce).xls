    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 110</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Culture, Body and Gender Roles</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2+0+0</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">24.06.2025</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Behaviours and gender roles that find reflection in the human body are shaped according to the society, culture, socioeconomic class and political environment experienced and can be changed according to need. These behaviors are influenced by power ideologies, social movements, social crises, and the current historical period.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411975&amp;lang=en</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">OK</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String"></Data></Cell>
   </Row>
