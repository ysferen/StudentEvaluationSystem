    <Cell ss:StyleID="s63"><Data ss:Type="String">ATA 102</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Ataturk's Principles and History of Revolution I</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2+0+0</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
