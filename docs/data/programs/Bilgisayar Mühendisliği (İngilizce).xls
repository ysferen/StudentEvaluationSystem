    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 517</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Mathematical Basis of Computational Neuroscience</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">12</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Testing models (E &amp; S) Getting parameters from the empirical data Prediction of basic effects and robustness acceptance criteria predictions of model sensitivity analysis</Data></Cell>
