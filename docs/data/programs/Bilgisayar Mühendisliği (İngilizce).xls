    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 175</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Creativity and Art</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2+0+0</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">24.06.2025</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Creativity, Types of Thinking, Barriers to creativity, techniques that improve creativity, creative writing studies, traditional classification of contemporary art, creative drama method in education, improvisation, play.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411823&amp;lang=en</Data></Cell>
