    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 103</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Nutrition for Healthy Living</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2+0+0</Data></Cell>
