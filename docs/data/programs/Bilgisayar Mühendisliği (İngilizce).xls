   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">CSE 101</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Introduction to Programming</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Learn basics of object-oriented programming</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411859&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ENG 105</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">English for Academic Purposes</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Identify common challenges in early higher education; be aware of expectations of higher education institutions; identify factors involved in good time management</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412038&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="45">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ENG 105</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">English for Academic Purposes</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Understand the requirements of writing an academmic essay; analyze essay questions; organize ideas to produce a clear outline; write an effective introduction with clear thesis statement; plan and structure the main part of an academic essay; writing a compelling conclusion; identify features of academic style, formal &amp; objective language</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412038&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="45">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ENG 105</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">English for Academic Purposes</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Identify key features of group work; recognize benefits and challenges of group work; set goals and objectives; plan and organize a group project; understand expectations in group discussions; employ useful language for contributing to academic discussions; identify verbal and non-verbal clues during conversations; identify techniques for encouraging and discourgaing interaction</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412038&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="45">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ENG 105</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">English for Academic Purposes</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Understand the difference between thinking and critical thinking, fact and opinion; identify parts of and evaluate arguments, recognize weak aguments; consider sources of bias in evidence in academic research; use critical thinking in a variety of styles to construct arguments</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412038&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ENG 105</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">English for Academic Purposes</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Structure and write a scientific report</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412038&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">MAT 111</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Calculus I</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
