    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">24.06.2025</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Popular Culture, Consumption Society, Culture Industry, Mass Communication Theories, Globalization, Popular Culture and Ideology, Effects of Media and Communication Patterns on Cultural Preferences, Social Transformation and Lifestyles, Popular Culture and Art, Sports, Fashion and Identity.</Data></Cell>
