    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">CSE 321</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Data Systems</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3+0+0</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">24.06.2025</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Relational Model, SQL, Entity Relationship, Data Aggregation, Indexes, Transactions and Concurrency.</Data></Cell>
