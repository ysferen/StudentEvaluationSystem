    <Cell ss:StyleID="s63"><Data ss:Type="String">Change Management</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">The concept of change, importance, scope, objectives, reasons, types, areas subject to change, factors causing organisational change, situations prone to change, dynamic and static organisation, change models, total quality management, bencmarking</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411971&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 187</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Design Thinking</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Participants will be able to understand the communication between different disciplines and practices, bring together different areas and parts of design and have the ability to create interdisciplinary perspectives and different designs.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411972&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 187</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Design Thinking</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Participants create a project by combining the different elements they have learnt.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411972&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 187</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Design Thinking</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Participants learn the basics of process management, understand the importance of teamwork in design projects and gain the ability to design holistically by adding the user experience dimension from design to production.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411972&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 187</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Design Thinking</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Participants create new applications by using their imagination, testing their designs, adding them to different projects</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411972&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 188</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Startup Design with Design Thinking</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">By understanding the communication between different disciplines and practices, participants can create a strong and shareable vision.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411845&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 188</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Startup Design with Design Thinking</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Participants can design a strategy by combining the different elements they have learnt.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411845&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 188</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Startup Design with Design Thinking</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Participants will learn the basics of process management, understand the importance of teamwork in design projects and be able to plan work.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411845&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 188</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Startup Design with Design Thinking</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Participants can design and realise a startup by using their imagination, testing their designs, adding them to different projects.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411845&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 188</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Startup Design with Design Thinking</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Participants can make a swot analysis of the Startup they designed. They can build growth plans for the Startup in question with innovation strategies.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411845&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 189</Data></Cell>
