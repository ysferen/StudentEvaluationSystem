    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 517</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Mathematical Basis of Computational Neuroscience</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">8</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Computer simulation of activity (Handout, Chap. 12 B&amp;B) simple HH channel Detailed presentation of specific models</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411841&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 517</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Mathematical Basis of Computational Neuroscience</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">9</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Detailed presentation of specific models Traub McCormicks thalamocortical cell Tutorial on McCormick/Huguenard models Try the voltage clamp without the fishy smell</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411841&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 517</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Mathematical Basis of Computational Neuroscience</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">10</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Channels model basics ion gated voltage gated Kinetic theory (Mainen and Sejnowski) GABA_A vs GABA_B second messengers</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411841&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 517</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Mathematical Basis of Computational Neuroscience</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">11</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Multiple levels of simulation Numeric approximation Simulating channel effects Example models Brown, others</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411841&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 517</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Mathematical Basis of Computational Neuroscience</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">12</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Full cell simulation (E &amp; S) 1 period {Readings: K&amp;S Chap. 4; Chap. 14 B&amp;B} Implementing multiple channels Determining empirical parameters Modeling the cortical microcircuit</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411841&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="45">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 517</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Mathematical Basis of Computational Neuroscience</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">13</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Population modeling (S) 2 periods { Readings Wilson &amp; Bower Chap. 9 K&amp;S; Chap. 17 B&amp;B; Chap. 3&amp;4 White; Douglas &amp; Martin 1992) } Please grab this lengthy paper for the next several lectures. Simplifying systems specialization receptive fields columns regions laminar distribution</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411841&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 517</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Mathematical Basis of Computational Neuroscience</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">14</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Simplified biological modeling Population activity in barrel fields (Dan Simons) 1 period using biological input and outputs problems of scaling how much and what kind of detail</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411841&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 519</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Functional Neuroimaging</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">to familiarize the students with a set of tools to analyze functional brain images in the service of scientific hypothesis testing.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412012&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 519</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Functional Neuroimaging</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">to develop a framework with which to understand what happens to the ground truth data we try to observe as it is processed through imaging tools.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412012&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 519</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Functional Neuroimaging</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">to give a solid background in the concepts common to many types of neuroimaging.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412012&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 519</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Functional Neuroimaging</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">to enable the students to form a causal link between the conveyed theoretical information and the practical outcome through the practicals and homeworks.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412012&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 519</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Functional Neuroimaging</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">to enable the students to comprehend how functional images are used in a theoretical context thorough analysis of sample journal papers which use various experimental designs to address neuroscientific questions</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412012&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
