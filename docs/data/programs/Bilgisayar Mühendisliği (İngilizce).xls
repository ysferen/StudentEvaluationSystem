    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 138</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Academic Turkish II</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Be able to systematically convey information and opinions on issues related to their field in written and oral form</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411890&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 138</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Academic Turkish II</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">7</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Adapt scientific research knowledge and skills on issues related to the field</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411890&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 138</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Academic Turkish II</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">8</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Be able to conduct an independent study that requires expertise in its field</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411890&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 138</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Academic Turkish II</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">9</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Evaluate academic Turkish course materials</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411890&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 139</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Öz yansıtma becerilerini geliştirerek öz farkındalığını artırır; değerlerinin, güçlü yanlarının, kör noktalarının ve bilişsel yanlılıklarının farkına varır.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412079&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 139</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Motivasyon kavram ve kuramlarını açıklar, etkili hedefler belirler ve bu hedeflere ulaşmak için plan yapar.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412079&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 139</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Etkili sunum ve hikaye anlatıcılığı için gerekli teknikleri öğrenir ve uygular, akranlarının performanslarını kritik bir gözle değerlendirir ve yapıcı geri bildirim verir.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412079&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 139</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Zamanı etkili yönetmek ve erteleme davranışının önüne geçmek için gerekli teknik ve becerileri öğrenir ve uygular.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412079&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 139</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Yaratıcılığı geliştiren düşünme biçim ve pratiklerini, sistematik problem çözme adımlarını ve farklı karar verme stillerini öğrenir ve uygular.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412079&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 139</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Stresi tanımlar, fark eder, stresin etkilerini bilir ve kendi stresini yönetmek için etkili teknikleri uygular.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412079&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 139</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">7</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Mindfulness ve öz şefkat kavramlarını tanımlar, faydalarını öğrenir, bu kavramları günlük hayatına entegre edecek teknik ve uygulamaları deneyimler.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412079&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 139</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">8</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Psikolojik sağlamlık kavramını açıklar ve kendi psikolojik sağlamlığını geliştirecek teknikleri uygular.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412079&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 139</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">9</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Farklı duyguları tanımlar, duyguların işlevlerini öğrenir, kendi duygusunu düzenlemesine destek olacak teknikleri uygular, duygusal zekayı tanımlar ve güçlendirecek pratikleri uygular.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412079&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 139</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">10</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Etkili iletişim ve çatışma yönetimi tekniklerini öğrenir ve uygular.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412079&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 139</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Life Skills for Psychological Wellbeing</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">11</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Farklı ilişkilenme türlerini ve bağlanma stillerini tanımlar, ilişkileri zora sokan dinamikleri öğrenir ve bunları yönetmek/ilişkileri güçlendirmek için uygun yaklaşımları uygular, ilişkilerde sağlıklı sınırları ve sınır çizmeyi öğrenir.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412079&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 140</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Marketing and Communication Management in Health Services</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Profesyonel sağlık işletmelerinde görev alacak, çağa uygun modern sağlık hizmeti pazarlama tekniklerini uygulayabilen ve en yüksek düzeyde sağlıklı iletişim yetkinliklerine sahip bireyler yetiştirmek…</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412069&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 141</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Introduction to Gender Equality</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Dersi tamamlayan öğrenci toplumsal Cinsiyet Kavramı Hakkında bilgi sahibi olacak</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412090&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 141</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Introduction to Gender Equality</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Dersi tamamlayan öğrenci Türkiye’de kadınlar için ekonomik eşitsizlik, eğitim ve istihdam sorunları hakkında tartışacak</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412090&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 141</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Introduction to Gender Equality</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Dersi tamamlayan öğrenci Kadın-Erkek eşitliği için yapılması gerekenleri sayabilecek</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412090&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 141</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Introduction to Gender Equality</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Dersi tamamlayan öğrenci toplumsal cinsiyet eşitliği ve kadın sağlığı hakları için yapılacak faaliyetler konusunda farkındalık sahibi olacaktır.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412090&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 142</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">History of World Culture and Civilisation</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Öğretim Görevlisi tarafından hazırlanacak sunum ve öğrenme çıktıları olarak sunulacaktır.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412071&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 143</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Ancient Philosophy</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Felsefe kavram ve problemlerini tanımlayabilme, edindiği kuramsal bilgileri felsefe problemlerine çözüm geliştirmede ve ortaya konan çözümlerin tartışılmasında kullanabilme becerisi.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412067&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 143</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Ancient Philosophy</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Felsefe alanında edindiği kuramsal ve pratiğe dönüştürülebilecek bilgileri; eğitim-öğretim, araştırma ve topluma hizmet alanlarında uygulama becerisi sunacaktır.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412067&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 143</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Ancient Philosophy</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Felsefe alanı ile ilgili bilgilerin uygulanması sürecinde etik değerlere ve evrensel hukuka uygun davranmayı gözetecektir.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412067&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 143</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Ancient Philosophy</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Disiplinler arası araştırma ve inceleme yapabilmek için gerekli kuramsal ve uygulamalı bilgiye sahip olması gereğini kavrayacaktır.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412067&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 143</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Ancient Philosophy</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Türkçe sözlü ve yazılı etkin iletişim kurma becerisini artıracaktır.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412067&amp;lang=en</Data></Cell>
   </Row>
