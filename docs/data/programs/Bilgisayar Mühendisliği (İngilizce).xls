    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 181</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Civil Society and Volunteering Activities</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Understand the role that NGOs play in our society and the nuances between publicly supported non-profit organizations and public/private foundations.</Data></Cell>
