    <Cell ss:StyleID="s63"><Data ss:Type="String">MBG 018</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Molecular Mechanisms of Disease</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3+0+0</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">7</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">24.06.2025</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Key Principles in Disease, Molecular mechanisms of the disease such as Inflammation and Immune Responses, Cardiovascular Diseases, Viral diseases, Aging, Alzheimer’s Disease, Infection and immunity, Cancer overview, Integrative techniques for health and disease, the effect of diet, Model systems for human biology and medicine</Data></Cell>
