    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">MBG 025</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Molecular Biology of Cancer</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3+0+0</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">7</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">24.06.2025</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">The Biology and Genetics of Cells and Organisms; The Nature of Cancer; Tumor Viruses; Cellular Oncogenes; Growth Factors and Receptors; Cytoplasmic Signaling Circuitry Programs; Tumor Suppressor Genes; pRb and Control of the Cell Cycle Clock; p53 and Apoptosis; The Hallmarks of Cancer</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411828&amp;lang=en</Data></Cell>
