    <Cell ss:StyleID="s63"><Data ss:Type="String">ACU 217</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">History of Cinema</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">More on Hollywood: The Studio System and Exceptional Auteurs (1930-1945) Genre development Films: Michael Curtiz, U.S, Casablanca (1942). Orson Welles, U.S., Citizen Kane (1941). Alfred Hitchcock, U.S., Rebecca (1940).</Data></Cell>
