    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">CSE 331</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Exploratory Data Analysis</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3+0+0</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">13.04.2026</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Data exploration, prediction, inference, visualization, statistical analysis</Data></Cell>
