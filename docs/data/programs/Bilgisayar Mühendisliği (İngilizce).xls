    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=411846&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
