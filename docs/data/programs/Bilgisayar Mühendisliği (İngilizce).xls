   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PHY 102</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Physics II</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Adopting the importance of lifelong learning, following the developments on scientific issues and being able to improve themselves.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412045&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">PHY 102</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Physics II</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">To understand the role and importance of physics on other branches of science.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412045&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">TUR 102</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Turkish Language II</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Students will develop language skills that are the basis of communication between people and groups.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412042&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">TUR 102</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Turkish Language II</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">By evaluating the language phenomenon with various dimensions such as language-thought, language-individual, Language-Society, language-culture, each student will understand how important language is in reality.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412042&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">TUR 102</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Turkish Language II</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Students will have the ability to use Turkish correctly, effectively and fluently as a means of oral and written expression.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412042&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">TUR 102</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Turkish Language II</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Students will be able to comprehend grammar issues, not just as the theoretical knowledge, but applications, observations and assessments on texts.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412042&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="45">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 105</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Humanities in Science</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Understand the requirements of writing an academmic essay; analyze essay questions; organize ideas to produce a clear outline; write an effective introduction with clear thesis statement; plan and structure the main part of an academic essay; writing a compelling conclusion; identify features of academic style, formal &amp; objective language</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412027&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 105</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Humanities in Science</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">2</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Work in groups/teams to identify common personality traits employers most look for in job applicants and for which students need improvementand/or development. Write an academic essay on a specified topic</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412027&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 105</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Humanities in Science</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">3</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Work in groups/teams to identify areas of a topical issue that intersect with the four pillars of medical ethics: Autonomy, Non-maleficence, Justice, and Beneficence. Write an academic essay on a specified topic.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412027&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 105</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Humanities in Science</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">4</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Work in groups/teams to identify areas of intersection between the principals of metaphysics and science/technology. Write an academic essay on a specified topic.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412027&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 105</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Humanities in Science</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">5</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Work in groups/teams to identify areas where historical dance development has paralleled social and economic historical development. Write an academic essay on a specified topic.</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=412027&amp;lang=en</Data></Cell>
   </Row>
   <Row ss:Height="30">
    <Cell ss:StyleID="s63"><Data ss:Type="String">Bilgisayar Mühendisliği (İngilizce)</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6246</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 105</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Humanities in Science</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">6</Data></Cell>
