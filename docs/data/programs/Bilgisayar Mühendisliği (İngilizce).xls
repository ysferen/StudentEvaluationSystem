    <Cell ss:StyleID="s63"><Data ss:Type="String">BME 510</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">Biosensors</Data></Cell>
    <Cell ss:StyleID="s63"><Data ss:Type="String">1</Data></Cell>
