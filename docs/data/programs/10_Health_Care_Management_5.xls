<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 223</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Modern Scientific Research Methods</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">21.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Scientific research methods, quantitative and qualitative study examples, data analysis through a statistical program, research results, publication and writing techniques, and reporting.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=425139&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 225</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Strategic Brand Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">21.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Course Content In this course, students will be informed about the key concepts of brand and marketing management. Marketing is a structured process, henceforth, the course will teach how to formulate strategies to engage new and current customers as well as generate sales. Students who attend this course are expected to improve their commercial focus and acquire skills to influence business growth.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=425140&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 226</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Project Management</Data></Cell>
