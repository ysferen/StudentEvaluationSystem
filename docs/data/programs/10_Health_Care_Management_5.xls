<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SYB 294</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Public Health</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">21.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The concept of public health and its historical development; protection and promotion of health; public health services in Turkey; Social Gender; Women&apos;s Health; regulation of fertility; Child and youth health, Infectious Diseases and immunization; Chronic Diseases and Elderly Health; employee health; environmental health; Accidents and injuries, Public health during disasters</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=425022&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
