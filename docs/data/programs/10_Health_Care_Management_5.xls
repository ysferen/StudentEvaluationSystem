<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">SYB 103</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Introduction to Business</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">21.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Business science and basic concepts, examination of the environment and economic conditions of the enterprise, establishment of enterprises: stages of establishment, location selection and capacity planning, growth and classification of enterprises, business functions: production management and finance management, marketing management, human resources management, public relations and communication process in business and modern approaches in business management.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=424998&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
</Row>
