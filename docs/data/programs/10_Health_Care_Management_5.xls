<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">21.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Microeconomics topics: price mechanism, market equilibrium, consumer behavior, production theories, firm equilibrium in a fully competitive market, trade, monopoly market equilibrium, firm equilibrium in incomplete competition, factor market, and firm equilibrium with concepts and theories.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=425043&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
