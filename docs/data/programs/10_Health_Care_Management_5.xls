<Cell ss:StyleID="Text"><Data ss:Type="String">Risk Management in Disasters</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3+0+0</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">21.08.2025</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Phases of emergency states, relationship between crisis and emergency, importance of being prepared in case of an emergency, principles of crisis management, crisis management examples in Turkey and in the world.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=425089&amp;lang=en</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">OK</Data></Cell>
