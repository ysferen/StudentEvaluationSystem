<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 143</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ancient Philosophy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Felsefe kavram ve problemlerini tanımlayabilme, edindiği kuramsal bilgileri felsefe problemlerine çözüm geliştirmede ve ortaya konan çözümlerin tartışılmasında kullanabilme becerisi.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=425095&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 143</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ancient Philosophy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Felsefe alanında edindiği kuramsal ve pratiğe dönüştürülebilecek bilgileri; eğitim-öğretim, araştırma ve topluma hizmet alanlarında uygulama becerisi sunacaktır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=425095&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 143</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Ancient Philosophy</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Felsefe alanı ile ilgili bilgilerin uygulanması sürecinde etik değerlere ve evrensel hukuka uygun davranmayı gözetecektir.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=425095&amp;lang=en</Data></Cell>
</Row>
