<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 142</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">History of World Culture and Civilisation</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
