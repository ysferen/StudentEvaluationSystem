<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 174</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Environmental Pollution and Climate Change</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">You can use a selected text in different emotions (angry, affectionate, curious, emotional, etc.) reading</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Practical, verbal, project development</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=425131&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 174</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Environmental Pollution and Climate Change</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">The use and importance of color as a form of connotation and expression in communication (disguise, clothing according to sociodemographic characteristics... etc.)</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Practical, verbal, project development</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String"></Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progCourseDetails.aspx?curCourse=425131&amp;lang=en</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">ACU 174</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Environmental Pollution and Climate Change</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Playing by making role changes with the stories and characters that the student has written and edited himself... Exchange of views on arousing empathy at the end of the lesson.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Practical, verbal, project development</Data></Cell>
