<Worksheet ss:Name="ProgramOutcomes">
<Table>
<Column ss:Width="220"/>
<Column ss:Width="70"/>
<Column ss:Width="110"/>
<Column ss:Width="750"/>
<Column ss:Width="420"/>
<Row>
<Cell ss:StyleID="Header"><Data ss:Type="String">ProgramName</Data></Cell>
<Cell ss:StyleID="Header"><Data ss:Type="String">ProgramId</Data></Cell>
<Cell ss:StyleID="Header"><Data ss:Type="String">ProgramOutcomeNo</Data></Cell>
<Cell ss:StyleID="Header"><Data ss:Type="String">ProgramOutcomeText</Data></Cell>
<Cell ss:StyleID="Header"><Data ss:Type="String">SourceUrl</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">1</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sağlık kurumlarının ve sisteminin yönetim, pazarlama, muhasebe-finans ve üretim fonksiyonlarında bilgi sahibi olur, bilgilerini stratejik, taktik ve operasyonel boyutlarda kullanır ve bu bilgileri örgütsel düzeyde analiz eder ve tasarlar.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">2</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sağlık alanında edindiği ileri düzeydeki bilgi ve becerileri kullanarak bilimsel olarak kanıtlanmış verileri yorumlar ve değerlendirir, sorunları tanımlayıp, analiz eder, mesleki ve etik değerleri gözeterek araştırmalara ve kanıtlara dayalı çözüm önerileri geliştirir.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">3</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Kamu ve özel sektör iş yaşamının gerektirdiği, hem teorik hem de uygulama bazındaki sağlık yönetimi yetkinlikleriyle iş yaşamına kolayca adaptasyon sağlar.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">4</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Bireysel olarak ve çok disiplinli takımlarda etkin çalışabilme becerisi, sorumluluk alma ve temsil etme özgüvenine sahip olur.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">İş öz-disiplinine sahip olur, işini sahiplenerek kaliteli iş yapar, yaptırır ve sonuçlandırır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">6</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Yaptığı uygulamaların insana dokunduğunun bilincinde olarak mesleki, hukuki, toplumsal ve etik sorumluluklarının farkında olur.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">7</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sosyal hakların evrenselliği, sosyal adalet, kalite, çevresel ve kültürel değerleri koruma, iş sağlığı ve güvenliğine önem verme konusunda gerekli bilinci kazanır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">8</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sağlık alanında toplumun ve dünyanın gündemindeki olayları ve gelişmeleri izler ve değerlendirir.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">9</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Sağlık yönetimi alanındaki bilimsel bilgilere ulaşır, güncel literatürü izler, değerlendirme ve uygulayabilme becerisini edinir.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">10</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Kendini ifade etme ve kurumunu temsil etme konusunda Türkçe’yi ve gerektiği yerde dil bilgisini doğru, kurallara uygun biçimde yazılı ve sözlü iletişimde kullanabilme beceri ve yeterliliğine sahip olur.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">11</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Yaşam boyu öğrenme, eleştirel düşünme, değişime açık olma ve girişimci ruha ilişkin olumlu tutum geliştirir ve davranışa dönüştürür.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">12</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Mesleki gelişmeleri takip edebilmek ve meslektaşları, hastaları ve toplum ile iletişim kurmak için İngilizceyi en az Avrupa Dil Portföyü B2 Genel Düzeyinde kullanır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Health Care Management</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">5</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">13</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Alanında bilgiye ulaşmak, yaygınlaştırmak için güncel bilişim ve iletişim teknolojilerini en az “Avrupa Bilgisayar Kullanma Lisansı Temel Düzeyinde” bilgisayar yazılımını etkin biçimde kullanır.</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">https://obs.acibadem.edu.tr/oibs/bologna/progLearnOutcomes.aspx?lang=tr&amp;curSunit=5</Data></Cell>
</Row>
</Table>
