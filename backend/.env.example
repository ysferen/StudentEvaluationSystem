# Django Core Settings
# ================================
# SECURITY WARNING: keep the secret key used in production secret!
# Generate a new one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here-change-in-production

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=True

# Allowed hosts - comma separated list
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# ================================
# Format: postgres://USER:PASSWORD@HOST:PORT/DB_NAME
#
# Option 1: SQLite (simple local development, no Docker needed)
# DATABASE_URL=sqlite:///db.sqlite3
#
# Option 2: PostgreSQL via Docker (recommended for team development)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/student_evaluation
#
# Option 3: PostgreSQL native (if running PostgreSQL locally without Docker)
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/student_evaluation

# CORS Configuration
# ================================
# Comma separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# JWT Configuration
# ================================
# Token lifetimes in minutes/hours/days
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Rate Limiting (Throttling)
# ================================
# Format: number/second, number/minute, number/hour, or number/day
# e.g., 5/minute, 100/hour, 1000/day
ANON_THROTTLE_RATE=100/day
USER_THROTTLE_RATE=1000/day
LOGIN_THROTTLE_RATE=5/minute
FILE_UPLOAD_THROTTLE_RATE=10/minute

# File Upload Settings
# ================================
MAX_UPLOAD_SIZE_MB=10

# Logging Level
# ================================
LOG_LEVEL=INFO
