[run]
source = student_evaluation_system
omit = 
    */migrations/*
    */tests/*
    */venv/*
    */virtualenv/*
    manage.py
    */settings.py
    */wsgi.py
    */asgi.py
    conftest.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
    class .*\bProtocol\):
    @(abc\.)?abstractmethod

show_missing = True
skip_covered = False
