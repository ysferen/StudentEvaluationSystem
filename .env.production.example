# Copy to .env, fill the 3 lines marked below, then run:
#   docker compose -f docker-compose.prod.yml up -d

# =============================================================================
# 1. Generate a secret key (paste the output of this command):
#    python -c "import secrets; print(secrets.token_urlsafe(50))"
# =============================================================================
SECRET_KEY=

# =============================================================================
# 2. Pick a database password
# =============================================================================
POSTGRES_PASSWORD=

# =============================================================================
# 3. Connection string — only change THE_PASSWORD to match POSTGRES_PASSWORD above
# =============================================================================
DATABASE_URL=postgres://postgres:THE_PASSWORD@db:5432/student_evaluation

# =============================================================================
# Everything below is optional — defaults work for a local Docker run.
# Uncomment and fill when deploying behind a real domain.
# =============================================================================

# ALLOWED_HOSTS=yourdomain.edu
# CORS_ALLOWED_ORIGINS=https://yourdomain.edu
# CSRF_TRUSTED_ORIGINS=https://yourdomain.edu
# VITE_API_URL=http://backend:8000
