# Production environment variables for Student Evaluation System
# Copy this file to .env and fill in real values before deploying.
#
# Generate a secure key with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"

# =============================================================================
# SECURITY
# =============================================================================
SECRET_KEY=

# Set to false (or leave unset) for production. Do NOT set to true.
# DEBUG=false

# Comma-separated list of your domain(s), e.g.:
# ALLOWED_HOSTS=ses.youruniversity.edu,www.ses.youruniversity.edu
ALLOWED_HOSTS=

# CORS / CSRF — match your frontend URL(s):
# CORS_ALLOWED_ORIGINS=https://ses.youruniversity.edu
# CSRF_TRUSTED_ORIGINS=https://ses.youruniversity.edu

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL=

POSTGRES_DB=student_evaluation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# =============================================================================
# EMAIL (optional — console backend prints to stdout if unset)
# =============================================================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=noreply@example.com
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@example.com

# =============================================================================
# FRONTEND (set in frontend/.env or frontend/.env.production)
# =============================================================================
VITE_API_URL=
# Usually: VITE_API_URL=/api (if using nginx reverse proxy)
# Or: VITE_API_URL=http://backend:8000 (if direct Docker networking)

# =============================================================================
# RATE LIMITING (optional — use code defaults if unset)
# =============================================================================
# ANON_THROTTLE_RATE=20/day
# USER_THROTTLE_RATE=200/day
# LOGIN_THROTTLE_RATE=5/minute
# FILE_UPLOAD_THROTTLE_RATE=10/minute

# =============================================================================
# LOGGING
# =============================================================================
# LOG_LEVEL=WARNING

# =============================================================================
# GUNICORN (backend server)
# =============================================================================
# GUNICORN_WORKERS=4
